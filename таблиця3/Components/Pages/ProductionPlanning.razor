  @order.StartDate.ToString("dd.MM.yy")
   }
   </td>
      <td>@order.SquareMeters.ToString("N0")</td>
      <td>
   @if (isEditing)
 {
       <input type="date" value="@EditProductionStartValue" @onchange="@((ChangeEventArgs e) => EditProductionStartValue = e.Value?.ToString() ?? string.Empty)" class="form-control form-control-sm" />
  }
          else
{
       @order.ProductionStartDate.ToString("dd.MM.yy")
}
  </td>
        <td>
       @if (isEditing)
{
       <input type="date" value="@EditProductionEndValue" @onchange="@((ChangeEventArgs e) => EditProductionEndValue = e.Value?.ToString() ?? string.Empty)" class="form-control form-control-sm" />
      }
     else
   {
   @order.ProductionEndDate.ToString("dd.MM.yy")
    }
        </td>
     <td>
 @if (isEditing)
 {
     <input type="date" value="@EditCompletionDateValue" @onchange="@((ChangeEventArgs e) => EditCompletionDateValue = e.Value?.ToString() ?? string.Empty)" class="form-control form-control-sm" />
      }
          else
      {
 @order.CompletionDate.ToString("dd.MM.yy")
    }
</td>
  <td>@order.ProductionDuration.ToString("F1")</td>
     <td class="text-center">
      @if (isEditing)
      {
    <div class="btn-group-sm" role="group">
 <button class="btn btn-success btn-sm" @onclick="() => SaveOrderEdit(3, order)" title="Зберегти">
      <i class="bi bi-check-lg"></i>
    </button>
    <button class="btn btn-secondary btn-sm" @onclick="CancelOrderEdit" title="Скасувати">
      <i class="bi bi-x-lg"></i>
     </button>
   </div>
   }
         else
      {
   <div class="btn-group-sm" role="group">
      <button class="btn btn-primary btn-sm" @onclick="() => StartOrderEdit(3, order)" title="Редагувати">
         <i class="bi bi-pencil"></i>
   </button>
      <button class="btn btn-danger btn-sm" @onclick="() => DeleteOrder(3, order.Day)" title="Видалити">
    <i class="bi bi-trash"></i>
        </button>
 </div>
       }
      </td>
    </tr>
    }
   </tbody>
   </table>
    </div>
     </div>
</div>
  }
        }
<!-- Цех №6 -->
        @if (schedule6 != null && schedule6.Orders.Any())
        {
 var filteredOrders6 = FilterOrders(schedule6.Orders).ToList();
            @if (filteredOrders6.Any())
      {
  <div class="card mb-4">
    <div class="card-header bg-warning text-white">
    <h5 class="mb-0">
     Замовлення для цеху №6
      <span class="badge bg-light text-dark ms-2">@filteredOrders6.Count</span>
     </h5>
 </div>
         <div class="card-body">
      <div class="table-responsive">
      <table class="table table-striped table-hover table-compact">
     <thead>
       <tr>
      <th>№</th>
  <th>Назва</th>
          <th>Статус</th>
 <th>Замовлення</th>
<th>Площа</th>
     <th>Старт</th>
          <th>Фініш</th>
        <th>Відвантаж.</th>
   <th>Днів</th>
  <th class="text-center">Дії</th>
     </tr>
  </thead>
          <tbody>
       @foreach (var order in filteredOrders6)
       {
   var isEditing = editingOrder?.Day == order.Day && editingOrder?.WorkshopNumber == 6;
  var status = order.GetStatus(filterDate);
    var statusClass = status switch {
      "В роботі" => "badge bg-success",
  "Очікує" => "badge bg-warning",
    "Завершено" => "badge bg-primary",
       _ => "badge bg-secondary"
       };
  <tr class="@(isEditing ? "table-warning" : "")">
     <td><strong>№@order.Day</strong></td>
    <td>
      @if (isEditing)
 {
 <input type="text" @bind="editOrderName" class="form-control form-control-sm" placeholder="Назва замовлення..." />
   }
    else
     {
   <span>@(string.IsNullOrWhiteSpace(order.OrderName) ? "(без назви)" : order.OrderName)</span>
      }
      </td>
       <td><span class="@statusClass">@status</span></td>
 <td>
    @if (isEditing)
  {
     <input type="date" value="@EditOrderDateValue" @onchange="@((ChangeEventArgs e) => EditOrderDateValue = e.Value?.ToString() ?? string.Empty)" class="form-control form-control-sm" />
  }
else
  {
   @order.StartDate.ToString("dd.MM.yy")
    }
         </td>
       <td>@order.SquareMeters.ToString("N0")</td>
       <td>
  @if (isEditing)
   {
        <input type="date" value="@EditProductionStartValue" @onchange="@((ChangeEventArgs e) => EditProductionStartValue = e.Value?.ToString() ?? string.Empty)" class="form-control form-control-sm" />
 }
  else
   {
          @order.ProductionStartDate.ToString("dd.MM.yy")
   }
      </td>
 <td>
       @if (isEditing)
      {
      <input type="date" value="@EditProductionEndValue" @onchange="@((ChangeEventArgs e) => EditProductionEndValue = e.Value?.ToString() ?? string.Empty)" class="form-control form-control-sm" />
  }
   else
    {
       @order.ProductionEndDate.ToString("dd.MM.yy")
  }
  </td>
  <td>
 @if (isEditing)
    {
     <input type="date" value="@EditCompletionDateValue" @onchange="@((ChangeEventArgs e) => EditCompletionDateValue = e.Value?.ToString() ?? string.Empty)" class="form-control form-control-sm" />
        }
 else
  {
      @order.CompletionDate.ToString("dd.MM.yy")
  }
  </td>
  <td>@order.ProductionDuration.ToString("F1")</td>
      <td class="text-center">
    @if (isEditing)
   {
     <div class="btn-group-sm" role="group">
       <button class="btn btn-success btn-sm" @onclick="() => SaveOrderEdit(6, order)" title="Зберегти">
  <i class="bi bi-check-lg"></i>
   </button>
   <button class="btn btn-secondary btn-sm" @onclick="CancelOrderEdit" title="Скасувати">
   <i class="bi bi-x-lg"></i>
    </button>
    </div>
    }
      else
      {
 <div class="btn-group-sm" role="group">
        <button class="btn btn-primary btn-sm" @onclick="() => StartOrderEdit(6, order)" title="Редагувати">
    <i class="bi bi-pencil"></i>
 </button>
<button class="btn btn-danger btn-sm" @onclick="() => DeleteOrder(6, order.Day)" title="Видалити">
        <i class="bi bi-trash"></i>
    </button>
       </div>
 }
  </td>
    </tr>
  }
    </tbody>
 </table>
       </div>
  </div>
   </div>
  }
    }
</div>
}