@page "/bulk-order-entry"
@using таблиця3.Models
@using таблиця3.Services
@inject ProductionPlanningService PlanningService
@inject DataStorageService StorageService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Масове Введення Замовлень</PageTitle>

<h1 class="mb-4">Масове Введення Замовлень для Всіх Цехів</h1>

<div class="row mb-4">
    <div class="col-12">
        <div class="alert alert-info">
      <i class="bi bi-info-circle"></i>
      <strong>Інформація:</strong> Ця форма дозволяє одночасно додати замовлення для всіх трьох цехів (№1, №3, №6) на одну дату.
            Введіть дату замовлення та обсяги для кожного цеху.
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">
            <i class="bi bi-calendar-plus"></i> Додати Замовлення для Всіх Цехів
    </h5>
  </div>
    <div class="card-body">
        <EditForm Model="@bulkOrder" OnValidSubmit="AddBulkOrder">
         <DataAnnotationsValidator />
      
            <!-- Дата замовлення -->
            <div class="row mb-4">
           <div class="col-md-4">
 <label class="form-label fw-bold">Дата Замовлення</label>
     <InputDate @bind-Value="bulkOrder.OrderDate" class="form-control" />
        <ValidationMessage For="@(() => bulkOrder.OrderDate)" />
     </div>
   </div>

            <hr />

            <!-- Цех №1 -->
            <div class="row mb-3">
           <div class="col-12">
<h5 class="text-primary">
      <i class="bi bi-building"></i> Цех №1
            </h5>
         </div>
  <div class="col-md-4">
    <label class="form-label">Замовлення 1</label>
        <input type="text" @bind="bulkOrder.Workshop1_Order1_Name" class="form-control form-control-sm mb-1" placeholder="Назва замовлення..." />
      <InputNumber @bind-Value="bulkOrder.Workshop1_Order1" class="form-control" placeholder="0 (м?)" />
      @if (bulkOrder.Workshop1_Order1 > 0)
     {
          <small class="text-muted">
       Тривалість: @((bulkOrder.Workshop1_Order1 / dailyCapacity).ToString("F2")) днів
   </small>
         }
    </div>
     <div class="col-md-4">
 <label class="form-label">Замовлення 2</label>
        <input type="text" @bind="bulkOrder.Workshop1_Order2_Name" class="form-control form-control-sm mb-1" placeholder="Назва замовлення..." />
     <InputNumber @bind-Value="bulkOrder.Workshop1_Order2" class="form-control" placeholder="0 (м?)" />
    @if (bulkOrder.Workshop1_Order2 > 0)
{
           <small class="text-muted">
Тривалість: @((bulkOrder.Workshop1_Order2 / dailyCapacity).ToString("F2")) днів
    </small>
     }
         </div>
       <div class="col-md-4">
    <label class="form-label">Замовлення 3</label>
      <input type="text" @bind="bulkOrder.Workshop1_Order3_Name" class="form-control form-control-sm mb-1" placeholder="Назва замовлення..." />
       <InputNumber @bind-Value="bulkOrder.Workshop1_Order3" class="form-control" placeholder="0 (м?)" />
   @if (bulkOrder.Workshop1_Order3 > 0)
 {
        <small class="text-muted">
         Тривалість: @((bulkOrder.Workshop1_Order3 / dailyCapacity).ToString("F2")) днів
   </small>
  }
     </div>
 </div>

            <hr />

  <!-- Цех №3 -->
        <div class="row mb-3">
  <div class="col-12">
   <h5 class="text-success">
       <i class="bi bi-building"></i> Цех №3
   </h5>
    </div>
<div class="col-md-4">
    <label class="form-label">Замовлення 1</label>
        <input type="text" @bind="bulkOrder.Workshop3_Order1_Name" class="form-control form-control-sm mb-1" placeholder="Назва замовлення..." />
     <InputNumber @bind-Value="bulkOrder.Workshop3_Order1" class="form-control" placeholder="0 (м?)" />
  @if (bulkOrder.Workshop3_Order1 > 0)
  {
         <small class="text-muted">
    Тривалість: @((bulkOrder.Workshop3_Order1 / dailyCapacity).ToString("F2")) днів
        </small>
   }
    </div>
       <div class="col-md-4">
  <label class="form-label">Замовлення 2</label>
      <input type="text" @bind="bulkOrder.Workshop3_Order2_Name" class="form-control form-control-sm mb-1" placeholder="Назва замовлення..." />
<InputNumber @bind-Value="bulkOrder.Workshop3_Order2" class="form-control" placeholder="0 (м?)" />
 @if (bulkOrder.Workshop3_Order2 > 0)
      {
      <small class="text-muted">
     Тривалість: @((bulkOrder.Workshop3_Order2 / dailyCapacity).ToString("F2")) днів
 </small>
   }
     </div>
         <div class="col-md-4">
    <label class="form-label">Замовлення 3</label>
      <input type="text" @bind="bulkOrder.Workshop3_Order3_Name" class="form-control form-control-sm mb-1" placeholder="Назва замовлення..." />
      <InputNumber @bind-Value="bulkOrder.Workshop3_Order3" class="form-control" placeholder="0 (м?)" />
          @if (bulkOrder.Workshop3_Order3 > 0)
       {
            <small class="text-muted">
       Тривалість: @((bulkOrder.Workshop3_Order3 / dailyCapacity).ToString("F2")) днів
        </small>
    }
    </div>
       </div>

       <hr />

          <!-- Цех №6 -->
    <div class="row mb-3">
  <div class="col-12">
        <h5 class="text-warning">
         <i class="bi bi-building"></i> Цех №6
       </h5>
 </div>
<div class="col-md-4">
  <label class="form-label">Замовлення 1</label>
        <input type="text" @bind="bulkOrder.Workshop6_Order1_Name" class="form-control form-control-sm mb-1" placeholder="Назва замовлення..." />
 <InputNumber @bind-Value="bulkOrder.Workshop6_Order1" class="form-control" placeholder="0 (м?)" />
   @if (bulkOrder.Workshop6_Order1 > 0)
     {
 <small class="text-muted">
  Тривалість: @((bulkOrder.Workshop6_Order1 / dailyCapacity).ToString("F2")) днів
</small>
   }
         </div>
     <div class="col-md-4">
        <label class="form-label">Замовлення 2</label>
     <input type="text" @bind="bulkOrder.Workshop6_Order2_Name" class="form-control form-control-sm mb-1" placeholder="Назва замовлення..." />
    <InputNumber @bind-Value="bulkOrder.Workshop6_Order2" class="form-control" placeholder="0 (м?)" />
     @if (bulkOrder.Workshop6_Order2 > 0)
       {
           <small class="text-muted">
        Тривалість: @((bulkOrder.Workshop6_Order2 / dailyCapacity).ToString("F2")) днів
     </small>
    }
      </div>
    <div class="col-md-4">
 <label class="form-label">Замовлення 3</label>
   <input type="text" @bind="bulkOrder.Workshop6_Order3_Name" class="form-control form-control-sm mb-1" placeholder="Назва замовлення..." />
   <InputNumber @bind-Value="bulkOrder.Workshop6_Order3" class="form-control" placeholder="0 (м?)" />
         @if (bulkOrder.Workshop6_Order3 > 0)
       {
      <small class="text-muted">
Тривалість: @((bulkOrder.Workshop6_Order3 / dailyCapacity).ToString("F2")) днів
 </small>
      }
</div>
     </div>

            <hr />

    <!-- Кнопки -->
     <div class="row">
     <div class="col-12">
      <button type="submit" class="btn btn-primary btn-lg" disabled="@isSaving">
    <i class="bi bi-check-circle"></i> @(isSaving ? "Збереження..." : "Додати Всі Замовлення")
         </button>
         <button type="button" class="btn btn-secondary btn-lg ms-2" @onclick="ClearForm">
      <i class="bi bi-x-circle"></i> Очистити
         </button>
<button type="button" class="btn btn-outline-primary btn-lg ms-2" @onclick="GoToPlanning">
     <i class="bi bi-arrow-left"></i> До Планування
    </button>
     </div>
            </div>

            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="alert alert-success mt-3">
 <i class="bi bi-check-circle"></i> @statusMessage
           </div>
            }
        </EditForm>
 </div>
</div>

<!-- Попередній перегляд -->
@if (HasAnyOrders())
{
    <div class="card mt-4">
        <div class="card-header bg-light">
       <h5 class="mb-0">Попередній Перегляд</h5>
     </div>
        <div class="card-body">
            <div class="table-responsive">
    <table class="table table-striped">
            <thead class="table-dark">
             <tr>
   <th>Цех</th>
     <th>Дата</th>
                <th>Замовлення 1</th>
   <th>Замовлення 2</th>
       <th>Замовлення 3</th>
            <th>Загалом</th>
           </tr>
</thead>
            <tbody>
       @if (bulkOrder.Workshop1_Order1 > 0 || bulkOrder.Workshop1_Order2 > 0 || bulkOrder.Workshop1_Order3 > 0)
 {
         <tr>
       <td><strong>Цех №1</strong></td>
       <td>@bulkOrder.OrderDate.ToString("dd.MM.yyyy")</td>
                <td>@bulkOrder.Workshop1_Order1.ToString("N0") м?</td>
             <td>@bulkOrder.Workshop1_Order2.ToString("N0") м?</td>
      <td>@bulkOrder.Workshop1_Order3.ToString("N0") м?</td>
          <td><strong>@((bulkOrder.Workshop1_Order1 + bulkOrder.Workshop1_Order2 + bulkOrder.Workshop1_Order3).ToString("N0")) м?</strong></td>
       </tr>
  }
       @if (bulkOrder.Workshop3_Order1 > 0 || bulkOrder.Workshop3_Order2 > 0 || bulkOrder.Workshop3_Order3 > 0)
             {
          <tr>
       <td><strong>Цех №3</strong></td>
        <td>@bulkOrder.OrderDate.ToString("dd.MM.yyyy")</td>
 <td>@bulkOrder.Workshop3_Order1.ToString("N0") м?</td>
      <td>@bulkOrder.Workshop3_Order2.ToString("N0") м?</td>
                  <td>@bulkOrder.Workshop3_Order3.ToString("N0") м?</td>
              <td><strong>@((bulkOrder.Workshop3_Order1 + bulkOrder.Workshop3_Order2 + bulkOrder.Workshop3_Order3).ToString("N0")) м?</strong></td>
          </tr>
        }
    @if (bulkOrder.Workshop6_Order1 > 0 || bulkOrder.Workshop6_Order2 > 0 || bulkOrder.Workshop6_Order3 > 0)
      {
           <tr>
           <td><strong>Цех №6</strong></td>
     <td>@bulkOrder.OrderDate.ToString("dd.MM.yyyy")</td>
    <td>@bulkOrder.Workshop6_Order1.ToString("N0") м?</td>
            <td>@bulkOrder.Workshop6_Order2.ToString("N0") м?</td>
               <td>@bulkOrder.Workshop6_Order3.ToString("N0") м?</td>
        <td><strong>@((bulkOrder.Workshop6_Order1 + bulkOrder.Workshop6_Order2 + bulkOrder.Workshop6_Order3).ToString("N0")) м?</strong></td>
        </tr>
         }
         </tbody>
                </table>
</div>
 </div>
    </div>
}

@code {
    private BulkOrderModel bulkOrder = new();
    private int dailyCapacity = 1000;
    private string statusMessage = string.Empty;
    private bool isSaving = false;

    [SupplyParameterFromQuery(Name = "date")]
    public string? InitialDate { get; set; }

    protected override void OnInitialized()
    {
 // Встановлюємо початкову дату
        if (!string.IsNullOrEmpty(InitialDate) && DateTime.TryParse(InitialDate, out var date))
        {
   bulkOrder.OrderDate = date;
        }
        else
      {
      bulkOrder.OrderDate = DateTime.Today;
        }
    }

    private bool HasAnyOrders()
    {
 return bulkOrder.Workshop1_Order1 > 0 || bulkOrder.Workshop1_Order2 > 0 || bulkOrder.Workshop1_Order3 > 0 ||
             bulkOrder.Workshop3_Order1 > 0 || bulkOrder.Workshop3_Order2 > 0 || bulkOrder.Workshop3_Order3 > 0 ||
               bulkOrder.Workshop6_Order1 > 0 || bulkOrder.Workshop6_Order2 > 0 || bulkOrder.Workshop6_Order3 > 0;
    }

 private async Task AddBulkOrder()
    {
        if (!HasAnyOrders())
      {
            statusMessage = "Будь ласка, введіть хоча б одне замовлення!";
      return;
        }

     isSaving = true;
     statusMessage = string.Empty;
     
        try
        {
      // Завантажуємо поточні дані
      var data = await StorageService.LoadWorkshopDataAsync() ?? new WorkshopData();
  
     // Ініціалізуємо словники якщо вони пусті
   if (data.WorkshopOrderDates == null || !data.WorkshopOrderDates.Any())
 {
   data.WorkshopOrderDates = new()
           {
         { 1, new List<DateTime>() },
      { 3, new List<DateTime>() },
   { 6, new List<DateTime>() }
    };
        }

     // Додаємо нові замовлення
         int totalOrders = 0;
     
     // Цех №1
        if (bulkOrder.Workshop1_Order1 > 0)
       {
     if (!data.WorkshopOrders.ContainsKey(1)) data.WorkshopOrders[1] = new List<double>();
  if (!data.WorkshopOrderDates.ContainsKey(1)) data.WorkshopOrderDates[1] = new List<DateTime>();
   if (!data.WorkshopOrderNames.ContainsKey(1)) data.WorkshopOrderNames[1] = new List<string>();
        
        data.WorkshopOrders[1].Add(bulkOrder.Workshop1_Order1);
       data.WorkshopOrderDates[1].Add(bulkOrder.OrderDate);
        data.WorkshopOrderNames[1].Add(bulkOrder.Workshop1_Order1_Name);
      totalOrders++;
  }
    if (bulkOrder.Workshop1_Order2 > 0)
{
   if (!data.WorkshopOrders.ContainsKey(1)) data.WorkshopOrders[1] = new List<double>();
  if (!data.WorkshopOrderDates.ContainsKey(1)) data.WorkshopOrderDates[1] = new List<DateTime>();
    if (!data.WorkshopOrderNames.ContainsKey(1)) data.WorkshopOrderNames[1] = new List<string>();
        
        data.WorkshopOrders[1].Add(bulkOrder.Workshop1_Order2);
        data.WorkshopOrderDates[1].Add(bulkOrder.OrderDate);
        data.WorkshopOrderNames[1].Add(bulkOrder.Workshop1_Order2_Name);
   totalOrders++;
          }
  if (bulkOrder.Workshop1_Order3 > 0)
    {
 if (!data.WorkshopOrders.ContainsKey(1)) data.WorkshopOrders[1] = new List<double>();
if (!data.WorkshopOrderDates.ContainsKey(1)) data.WorkshopOrderDates[1] = new List<DateTime>();
        if (!data.WorkshopOrderNames.ContainsKey(1)) data.WorkshopOrderNames[1] = new List<string>();
    
       data.WorkshopOrders[1].Add(bulkOrder.Workshop1_Order3);
     data.WorkshopOrderDates[1].Add(bulkOrder.OrderDate);
 data.WorkshopOrderNames[1].Add(bulkOrder.Workshop1_Order3_Name);
         totalOrders++;
    }
    
    // Цех №3
 if (bulkOrder.Workshop3_Order1 > 0)
    {
    if (!data.WorkshopOrders.ContainsKey(3)) data.WorkshopOrders[3] = new List<double>();
        if (!data.WorkshopOrderDates.ContainsKey(3)) data.WorkshopOrderDates[3] = new List<DateTime>();
        if (!data.WorkshopOrderNames.ContainsKey(3)) data.WorkshopOrderNames[3] = new List<string>();
        
 data.WorkshopOrders[3].Add(bulkOrder.Workshop3_Order1);
    data.WorkshopOrderDates[3].Add(bulkOrder.OrderDate);
    data.WorkshopOrderNames[3].Add(bulkOrder.Workshop3_Order1_Name);
     totalOrders++;
    }
       if (bulkOrder.Workshop3_Order2 > 0)
  {
 if (!data.WorkshopOrders.ContainsKey(3)) data.WorkshopOrders[3] = new List<double>();
      if (!data.WorkshopOrderDates.ContainsKey(3)) data.WorkshopOrderDates[3] = new List<DateTime>();
    if (!data.WorkshopOrderNames.ContainsKey(3)) data.WorkshopOrderNames[3] = new List<string>();
        
    data.WorkshopOrders[3].Add(bulkOrder.Workshop3_Order2);
     data.WorkshopOrderDates[3].Add(bulkOrder.OrderDate);
   data.WorkshopOrderNames[3].Add(bulkOrder.Workshop3_Order2_Name);
      totalOrders++;
 }
        if (bulkOrder.Workshop3_Order3 > 0)
      {
     if (!data.WorkshopOrders.ContainsKey(3)) data.WorkshopOrders[3] = new List<double>();
      if (!data.WorkshopOrderDates.ContainsKey(3)) data.WorkshopOrderDates[3] = new List<DateTime>();
  if (!data.WorkshopOrderNames.ContainsKey(3)) data.WorkshopOrderNames[3] = new List<string>();
        
 data.WorkshopOrders[3].Add(bulkOrder.Workshop3_Order3);
       data.WorkshopOrderDates[3].Add(bulkOrder.OrderDate);
        data.WorkshopOrderNames[3].Add(bulkOrder.Workshop3_Order3_Name);
totalOrders++;
      }
     
    // Цех №6
      if (bulkOrder.Workshop6_Order1 > 0)
 {
        if (!data.WorkshopOrders.ContainsKey(6)) data.WorkshopOrders[6] = new List<double>();
       if (!data.WorkshopOrderDates.ContainsKey(6)) data.WorkshopOrderDates[6] = new List<DateTime>();
 if (!data.WorkshopOrderNames.ContainsKey(6)) data.WorkshopOrderNames[6] = new List<string>();
        
     data.WorkshopOrders[6].Add(bulkOrder.Workshop6_Order1);
    data.WorkshopOrderDates[6].Add(bulkOrder.OrderDate);
        data.WorkshopOrderNames[6].Add(bulkOrder.Workshop6_Order1_Name);
   totalOrders++;
       }
    if (bulkOrder.Workshop6_Order2 > 0)
     {
       if (!data.WorkshopOrders.ContainsKey(6)) data.WorkshopOrders[6] = new List<double>();
      if (!data.WorkshopOrderDates.ContainsKey(6)) data.WorkshopOrderDates[6] = new List<DateTime>();
        if (!data.WorkshopOrderNames.ContainsKey(6)) data.WorkshopOrderNames[6] = new List<string>();
      
 data.WorkshopOrders[6].Add(bulkOrder.Workshop6_Order2);
    data.WorkshopOrderDates[6].Add(bulkOrder.OrderDate);
        data.WorkshopOrderNames[6].Add(bulkOrder.Workshop6_Order2_Name);
         totalOrders++;
    }
    if (bulkOrder.Workshop6_Order3 > 0)
 {
     if (!data.WorkshopOrders.ContainsKey(6)) data.WorkshopOrders[6] = new List<double>();
  if (!data.WorkshopOrderDates.ContainsKey(6)) data.WorkshopOrderDates[6] = new List<DateTime>();
   if (!data.WorkshopOrderNames.ContainsKey(6)) data.WorkshopOrderNames[6] = new List<string>();
        
   data.WorkshopOrders[6].Add(bulkOrder.Workshop6_Order3);
    data.WorkshopOrderDates[6].Add(bulkOrder.OrderDate);
        data.WorkshopOrderNames[6].Add(bulkOrder.Workshop6_Order3_Name);
   totalOrders++;
    }

   // Зберігаємо дані
          await StorageService.SaveWorkshopDataAsync(data);
         
   statusMessage = $"? Успішно додано {totalOrders} замовлення на дату {bulkOrder.OrderDate:dd.MM.yyyy} та збережено!";
      
  // Очищуємо форму після успішного збереження
 await Task.Delay(2000);
 ClearForm();
    }
        catch (Exception ex)
        {
 statusMessage = $"? Помилка збереження: {ex.Message}";
        }
        finally
        {
         isSaving = false;
 }
    }

    private void ClearForm()
    {
        bulkOrder = new BulkOrderModel { OrderDate = DateTime.Today };
        statusMessage = string.Empty;
    }

    private void GoToPlanning()
{
Navigation.NavigateTo("/production-planning");
    }

    // Модель для масового введення
    public class BulkOrderModel
    {
   public DateTime OrderDate { get; set; } = DateTime.Today;
  
        // Цех №1
   public string Workshop1_Order1_Name { get; set; } = string.Empty;
    public double Workshop1_Order1 { get; set; }
        public string Workshop1_Order2_Name { get; set; } = string.Empty;
        public double Workshop1_Order2 { get; set; }
        public string Workshop1_Order3_Name { get; set; } = string.Empty;
    public double Workshop1_Order3 { get; set; }
    
  // Цех №3
        public string Workshop3_Order1_Name { get; set; } = string.Empty;
      public double Workshop3_Order1 { get; set; }
        public string Workshop3_Order2_Name { get; set; } = string.Empty;
   public double Workshop3_Order2 { get; set; }
        public string Workshop3_Order3_Name { get; set; } = string.Empty;
    public double Workshop3_Order3 { get; set; }
        
  // Цех №6
        public string Workshop6_Order1_Name { get; set; } = string.Empty;
        public double Workshop6_Order1 { get; set; }
        public string Workshop6_Order2_Name { get; set; } = string.Empty;
        public double Workshop6_Order2 { get; set; }
        public string Workshop6_Order3_Name { get; set; } = string.Empty;
        public double Workshop6_Order3 { get; set; }
    }
}
