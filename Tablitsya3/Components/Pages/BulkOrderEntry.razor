 data.WorkshopOrders[6].Add(bulkOrder.Workshop6_Order2);
    data.WorkshopOrderDates[6].Add(bulkOrder.OrderDate);
        data.WorkshopOrderNames[6].Add(bulkOrder.Workshop6_Order2_Name);
