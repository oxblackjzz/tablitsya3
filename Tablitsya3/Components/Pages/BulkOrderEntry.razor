    [SupplyParameterFromQuery(Name = "date")]
    public string? InitialDate { get; set; }

    protected override void OnInitialized()
    {
 // ������������ ��������� ����
        if (!string.IsNullOrEmpty(InitialDate) && DateTime.TryParse(InitialDate, out var date))
        {
   bulkOrder.OrderDate = date;
        }
        else
      {
      bulkOrder.OrderDate = DateTime.Today;
        }
    }

    private bool HasAnyOrders()
    {
 return bulkOrder.Workshop1_Order1 > 0 || bulkOrder.Workshop1_Order2 > 0 || bulkOrder.Workshop1_Order3 > 0 ||
             bulkOrder.Workshop3_Order1 > 0 || bulkOrder.Workshop3_Order2 > 0 || bulkOrder.Workshop3_Order3 > 0 ||
               bulkOrder.Workshop6_Order1 > 0 || bulkOrder.Workshop6_Order2 > 0 || bulkOrder.Workshop6_Order3 > 0;
    }

 private async Task AddBulkOrder()
    {
        if (!HasAnyOrders())
      {
            statusMessage = "���� �����, ������ ���� � ���� ����������!";
      return;
        }

     isSaving = true;
     statusMessage = string.Empty;
     
        try
        {
      // ����������� ������ ���
      var data = await StorageService.LoadWorkshopDataAsync() ?? new WorkshopData();
  
     // ���������� �������� ���� ���� ����
   if (data.WorkshopOrderDates == null || !data.WorkshopOrderDates.Any())
 {
   data.WorkshopOrderDates = new()
           {
         { 1, new List<DateTime>() },
      { 3, new List<DateTime>() },
   { 6, new List<DateTime>() }
    };
        }

     // ������ ��� ����������
         int totalOrders = 0;
     
     // ��� �1
        if (bulkOrder.Workshop1_Order1 > 0)
       {
     if (!data.WorkshopOrders.ContainsKey(1)) data.WorkshopOrders[1] = new List<double>();
  if (!data.WorkshopOrderDates.ContainsKey(1)) data.WorkshopOrderDates[1] = new List<DateTime>();
   if (!data.WorkshopOrderNames.ContainsKey(1)) data.WorkshopOrderNames[1] = new List<string>();
        
        data.WorkshopOrders[1].Add(bulkOrder.Workshop1_Order1);
       data.WorkshopOrderDates[1].Add(bulkOrder.OrderDate);
        data.WorkshopOrderNames[1].Add(bulkOrder.Workshop1_Order1_Name);
      totalOrders++;
  }
    if (bulkOrder.Workshop1_Order2 > 0)
{
   if (!data.WorkshopOrders.ContainsKey(1)) data.WorkshopOrders[1] = new List<double>();
  if (!data.WorkshopOrderDates.ContainsKey(1)) data.WorkshopOrderDates[1] = new List<DateTime>();
    if (!data.WorkshopOrderNames.ContainsKey(1)) data.WorkshopOrderNames[1] = new List<string>();
        
        data.WorkshopOrders[1].Add(bulkOrder.Workshop1_Order2);
        data.WorkshopOrderDates[1].Add(bulkOrder.OrderDate);
        data.WorkshopOrderNames[1].Add(bulkOrder.Workshop1_Order2_Name);
   totalOrders++;
          }
  if (bulkOrder.Workshop1_Order3 > 0)
    {
 if (!data.WorkshopOrders.ContainsKey(1)) data.WorkshopOrders[1] = new List<double>();
if (!data.WorkshopOrderDates.ContainsKey(1)) data.WorkshopOrderDates[1] = new List<DateTime>();
        if (!data.WorkshopOrderNames.ContainsKey(1)) data.WorkshopOrderNames[1] = new List<string>();
    
       data.WorkshopOrders[1].Add(bulkOrder.Workshop1_Order3);
     data.WorkshopOrderDates[1].Add(bulkOrder.OrderDate);
 data.WorkshopOrderNames[1].Add(bulkOrder.Workshop1_Order3_Name);
         totalOrders++;
    }
    
    // ��� �3
 if (bulkOrder.Workshop3_Order1 > 0)
    {
    if (!data.WorkshopOrders.ContainsKey(3)) data.WorkshopOrders[3] = new List<double>();
        if (!data.WorkshopOrderDates.ContainsKey(3)) data.WorkshopOrderDates[3] = new List<DateTime>();
        if (!data.WorkshopOrderNames.ContainsKey(3)) data.WorkshopOrderNames[3] = new List<string>();
        
 data.WorkshopOrders[3].Add(bulkOrder.Workshop3_Order1);
    data.WorkshopOrderDates[3].Add(bulkOrder.OrderDate);
    data.WorkshopOrderNames[3].Add(bulkOrder.Workshop3_Order1_Name);
     totalOrders++;
    }
       if (bulkOrder.Workshop3_Order2 > 0)
  {
 if (!data.WorkshopOrders.ContainsKey(3)) data.WorkshopOrders[3] = new List<double>();
      if (!data.WorkshopOrderDates.ContainsKey(3)) data.WorkshopOrderDates[3] = new List<DateTime>();
    if (!data.WorkshopOrderNames.ContainsKey(3)) data.WorkshopOrderNames[3] = new List<string>();
        
    data.WorkshopOrders[3].Add(bulkOrder.Workshop3_Order2);
     data.WorkshopOrderDates[3].Add(bulkOrder.OrderDate);
