    if (bulkOrder.Workshop6_Order3 > 0)
 {
     if (!data.WorkshopOrders.ContainsKey(6)) data.WorkshopOrders[6] = new List<double>();
  if (!data.WorkshopOrderDates.ContainsKey(6)) data.WorkshopOrderDates[6] = new List<DateTime>();
