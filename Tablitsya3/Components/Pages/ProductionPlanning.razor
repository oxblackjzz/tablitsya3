@page "/production-planning"
@using Tablitsya3.Models
@using Tablitsya3.Services
@rendermode InteractiveServer

<PageTitle>Планування виробництва</PageTitle>

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">
            <i class="bi bi-bar-chart-fill text-primary"></i> Діаграми виробництва
        </h1>
        <p class="text-secondary mb-0">Візуалізація завантаження цехів (діаграми Ганта)</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/orders" class="btn btn-outline-primary">
            <i class="bi bi-table"></i> Таблиці замовлень
        </a>
        <a href="/bulk-order-entry" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Додати замовлення
        </a>
    </div>
</div>

<!-- Кнопки управління -->
<div class="card mb-4">
    <div class="card-body">
        <div class="d-flex flex-wrap gap-2">
            <button class="btn btn-primary" @onclick="CalculateAllSchedules">
                <i class="bi bi-calculator-fill"></i> Розрахувати графіки
            </button>
            <button class="btn btn-outline-warning" @onclick="ForceRecalculate">
                <i class="bi bi-arrow-repeat"></i> Примусовий перерахунок
            </button>
            <button class="btn btn-outline-success" @onclick="SaveAllData" disabled="@(!hasSchedules)">
                <i class="bi bi-save-fill"></i> Зберегти
            </button>
            <button class="btn btn-outline-secondary" @onclick="LoadData">
                <i class="bi bi-arrow-clockwise"></i> Оновити
            </button>
            <button class="btn btn-outline-info" @onclick="CreateBackup">
                <i class="bi bi-cloud-arrow-up"></i> Бекап
            </button>
            <a href="/workshop-settings" class="btn btn-outline-secondary">
                <i class="bi bi-sliders"></i> Налаштування цехів
            </a>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert @(statusMessage.Contains("❌") ? "alert-danger" : "alert-success") alert-dismissible fade show">
        @statusMessage
        <button type="button" class="btn-close" @onclick="() => statusMessage = string.Empty"></button>
    </div>
}

<!-- Статистика по цехах -->
@if (hasSchedules)
{
    <div class="row g-4 mb-4">
        @foreach (var workshop in workshops.OrderBy(w => w.SortOrder))
        {
            var schedule = GetSchedule(workshop.Number);
            if (schedule != null && schedule.Orders.Any())
            {
                <div class="col-md-6 col-lg-4">
                    <div class="stat-card @(workshop.ColorClass == "warning" ? "warning" : workshop.ColorClass == "success" ? "success" : workshop.ColorClass == "danger" ? "danger" : "info")">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="mb-1 opacity-75">@workshop.Name</p>
                                <h3>@schedule.Orders.Count замовлень</h3>
                                <small class="opacity-75">
                                    @schedule.Orders.Sum(o => o.SquareMeters).ToString("N0") м² | 
                                    @schedule.Orders.Sum(o => o.ProductionDuration).ToString("F1") днів
                                </small>
                            </div>
                            <i class="bi bi-building fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
}

<!-- Фільтр -->
@if (hasSchedules)
{
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-funnel"></i> Фільтр замовлень
                    </label>
                    <select class="form-select" @bind="orderFilter">
                        <option value="all">Усі замовлення (@GetTotalOrdersCount())</option>
                        <option value="in-production">В роботі (@GetInProductionCount())</option>
                        <option value="not-started">Очікують (@GetNotStartedCount())</option>
                        <option value="completed">Завершено (@GetCompletedCount())</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-calendar"></i> Дата статусу
                    </label>
                    <input type="date" class="form-control" @bind="filterDate" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-calendar-range"></i> Початок планування
                    </label>
                    <InputDate @bind-Value="workshopData.StartDate" class="form-control" />
                </div>
            </div>
        </div>
    </div>
}

<!-- Діаграми Ганта -->
@if (hasSchedules)
{
    @foreach (var workshop in workshops.OrderBy(w => w.SortOrder))
    {
        var schedule = GetSchedule(workshop.Number);
        if (schedule != null && schedule.Orders.Any())
        {
            var filteredOrders = FilterOrders(schedule.Orders).ToList();
            if (filteredOrders.Any())
            {
                <div class="card mb-4">
                    <div class="card-header bg-@workshop.ColorClass @(workshop.ColorClass == "warning" ? "text-dark" : "text-white") d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-building"></i> @workshop.Name
                            <span class="badge bg-light text-dark ms-2">@filteredOrders.Count</span>
                        </h5>
                        <a href="/orders" class="btn btn-sm btn-light">
                            <i class="bi bi-table"></i> Детальна таблиця
                        </a>
                    </div>
                    <div class="card-body">
                        <GanttChart 
                            @key="@($"gantt-{workshop.Number}-{ganttChartKey}")"
                            WorkshopNumber="@workshop.Number" 
                            Orders="@filteredOrders" 
                            StartDate="@workshopData.StartDate"
                            DailyCapacity="@workshopData.GetCapacity(workshop.Number)" />
                    </div>
                </div>
            }
            else if (orderFilter != "all")
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i>
                    <strong>@workshop.Name:</strong> Немає замовлень за фільтром "@GetFilterName()".
                </div>
            }
        }
    }
}
else if (workshopData.WorkshopOrders.Any())
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle"></i>
        <strong>Є необроблені замовлення!</strong> Натисніть "Розрахувати графіки" для перегляду.
    </div>
}
else
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i>
        <strong>Замовлень поки немає.</strong> 
        <a href="/bulk-order-entry" class="alert-link">Додайте замовлення</a> або 
        <a href="/orders" class="alert-link">перегляньте таблицю</a>.
    </div>
}
