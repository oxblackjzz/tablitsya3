@page "/orders"
@using Tablitsya3.Models
@using Tablitsya3.Services
@inject UnifiedStorageService StorageService
@inject WorkshopConfigService WorkshopConfigService
@inject ProductionPlanningService PlanningService
@inject WorkingDaysService WorkingDays
@inject BackupService BackupService
@inject LoggingService Logger
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Замовлення - Планування виробництва</PageTitle>

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">
            <i class="bi bi-table text-primary"></i> Замовлення
        </h1>
        <p class="text-secondary mb-0">Детальний перегляд та редагування замовлень по цехах</p>
    </div>
    <div class="d-flex gap-2">
        @if (hasDuplicates)
        {
            <button class="btn btn-warning" @onclick="CleanupDuplicates">
                <i class="bi bi-exclamation-triangle"></i> Видалити дублі (@duplicateCount)
            </button>
        }
        <a href="/production-planning" class="btn btn-outline-primary">
            <i class="bi bi-bar-chart-fill"></i> Діаграми Ганта
        </a>
        <a href="/bulk-order-entry" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Додати замовлення
        </a>
    </div>
</div>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Завантаження...</span>
        </div>
        <p class="mt-3 text-secondary">Завантаження даних...</p>
    </div>
}
else if (!hasSchedules)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>
        <strong>Немає даних</strong>
        <p class="mb-2">Спочатку потрібно розрахувати графіки на сторінці планування.</p>
        <a href="/production-planning" class="btn btn-primary">
            <i class="bi bi-calculator"></i> Перейти до планування
        </a>
    </div>
}
else
{
    <!-- Фільтри -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-funnel"></i> Фільтр замовлень
                    </label>
                    <select class="form-select" @bind="orderFilter">
                        <option value="all">Усі (@GetTotalOrdersCount())</option>
                        <option value="in-production">В роботі (@GetInProductionCount())</option>
                        <option value="not-started">Очікують (@GetNotStartedCount())</option>
                        <option value="completed">Завершено (@GetCompletedCount())</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-building"></i> Цех
                    </label>
                    <select class="form-select" @bind="selectedWorkshop">
                        <option value="0">Усі цехи</option>
                        @foreach (var workshop in workshops.OrderBy(w => w.SortOrder))
                        {
                            <option value="@workshop.Number">@workshop.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-search"></i> Пошук
                    </label>
                    <input type="text" class="form-control" placeholder="Назва замовлення..." 
                           @bind="searchQuery" @bind:event="oninput" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-calendar"></i> Дата фільтру
                    </label>
                    <input type="date" class="form-control" @bind="filterDate" />
                </div>
            </div>
        </div>
    </div>

    <!-- Таблиці по цехах -->
    @foreach (var workshop in GetFilteredWorkshops())
    {
        var schedule = GetSchedule(workshop.Number);
        if (schedule != null && schedule.Orders.Any())
        {
            var filteredOrders = FilterOrders(schedule.Orders, workshop.Number).ToList();
            if (filteredOrders.Any())
            {
                <div class="card mb-4">
                    <div class="card-header bg-@workshop.ColorClass @(workshop.ColorClass == "warning" ? "text-dark" : "text-white") d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-building"></i> @workshop.Name
                            <span class="badge bg-light text-dark ms-2">@filteredOrders.Count замовлень</span>
                        </h5>
                        <div class="d-flex gap-2 align-items-center">
                            <span class="badge bg-light text-dark">
                                <i class="bi bi-speedometer2"></i> @workshopData.GetCapacity(workshop.Number) м²/день
                            </span>
                            @if (dragDropEnabled)
                            {
                                <span class="badge bg-light text-dark">
                                    <i class="bi bi-grip-vertical"></i> Drag & Drop
                                </span>
                            }
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 40px;"></th>
                                        <th style="width: 60px;">№</th>
                                        <th>Назва</th>
                                        <th style="width: 100px;">Статус</th>
                                        <th style="width: 100px;">Замовлення</th>
                                        <th style="width: 80px;">Площа</th>
                                        <th style="width: 100px;">Старт</th>
                                        <th style="width: 100px;">Фініш</th>
                                        <th style="width: 100px;">Відвантаж.</th>
                                        <th style="width: 60px;">Днів</th>
                                        <th style="width: 100px;" class="text-center">Дії</th>
                                    </tr>
                                </thead>
                                <tbody id="orders-table-@workshop.Number" data-workshop="@workshop.Number">
                                    @foreach (var order in filteredOrders)
                                    {
                                        var isEditing = editingOrder?.Day == order.Day && editingOrder?.WorkshopNumber == workshop.Number;
                                        var status = order.GetStatus(filterDate);
                                        var statusClass = status switch {
                                            "В роботі" => "badge bg-success",
                                            "Очікує" => "badge bg-warning text-dark",
                                            "Завершено" => "badge bg-primary",
                                            _ => "badge bg-secondary"
                                        };
                                        
                                        <tr class="draggable-row @(isEditing ? "table-warning" : "")" data-order-day="@order.Day">
                                            <td class="drag-handle text-center" title="Перетягніть для зміни порядку">
                                                <i class="bi bi-grip-vertical text-muted"></i>
                                            </td>
                                            <td><strong>@order.Day</strong></td>
                                            <td>
                                                @if (isEditing)
                                                {
                                                    <input type="text" @bind="editOrderName" class="form-control form-control-sm no-drag" placeholder="Назва..." />
                                                }
                                                else
                                                {
                                                    <span class="@(string.IsNullOrWhiteSpace(order.OrderName) ? "text-muted" : "")">
                                                        @(string.IsNullOrWhiteSpace(order.OrderName) ? "(без назви)" : order.OrderName)
                                                    </span>
                                                }
                                            </td>
                                            <td><span class="@statusClass">@status</span></td>
                                            <td>
                                                @if (isEditing)
                                                {
                                                    <input type="date" value="@EditOrderDateValue" 
                                                           @onchange="@(e => EditOrderDateValue = e.Value?.ToString() ?? string.Empty)" 
                                                           class="form-control form-control-sm no-drag" />
                                                }
                                                else
                                                {
                                                    @order.StartDate.ToString("dd.MM.yy")
                                                }
                                            </td>
                                            <td class="text-end">
                                                @if (isEditing)
                                                {
                                                    <input type="number" @bind="editSquareMeters" 
                                                           class="form-control form-control-sm no-drag" 
                                                           min="1" max="100000" step="1"
                                                           style="width: 90px;" />
                                                }
                                                else
                                                {
                                                    @order.SquareMeters.ToString("N0") <span class="text-muted">м²</span>
                                                }
                                            </td>
                                            <td>
                                                @if (isEditing)
                                                {
                                                    <input type="date" value="@EditProductionStartValue" 
                                                           @onchange="@(e => EditProductionStartValue = e.Value?.ToString() ?? string.Empty)" 
                                                           class="form-control form-control-sm no-drag" />
                                                }
                                                else
                                                {
                                                    @order.ProductionStartDate.ToString("dd.MM.yy")
                                                }
                                            </td>
                                            <td>
                                                @if (isEditing)
                                                {
                                                    <input type="date" value="@EditProductionEndValue" 
                                                           @onchange="@(e => EditProductionEndValue = e.Value?.ToString() ?? string.Empty)" 
                                                           class="form-control form-control-sm no-drag" />
                                                }
                                                else
                                                {
                                                    @order.ProductionEndDate.ToString("dd.MM.yy")
                                                }
                                            </td>
                                            <td>
                                                @if (isEditing)
                                                {
                                                    <input type="date" value="@EditCompletionDateValue" 
                                                           @onchange="@(e => EditCompletionDateValue = e.Value?.ToString() ?? string.Empty)" 
                                                           class="form-control form-control-sm no-drag" />
                                                }
                                                else
                                                {
                                                    @order.CompletionDate.ToString("dd.MM.yy")
                                                }
                                            </td>
                                            <td class="text-center">@order.ProductionDuration.ToString("F1")</td>
                                            <td class="text-center no-drag">
                                                @if (isEditing)
                                                {
                                                    <div class="btn-group btn-group-sm">
                                                        <button class="btn btn-success btn-sm" @onclick="() => SaveOrderEdit(workshop.Number, order)" title="Зберегти">
                                                            <i class="bi bi-check-lg"></i>
                                                        </button>
                                                        <button class="btn btn-secondary btn-sm" @onclick="CancelOrderEdit" title="Скасувати">
                                                            <i class="bi bi-x-lg"></i>
                                                        </button>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="btn-group btn-group-sm">
                                                        <button class="btn btn-outline-primary btn-sm" @onclick="() => StartOrderEdit(workshop.Number, order)" title="Редагувати">
                                                            <i class="bi bi-pencil"></i>
                                                        </button>
                                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteOrder(workshop.Number, order.Day)" title="Видалити">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </div>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="card-footer bg-light">
                        <div class="row text-center">
                            <div class="col">
                                <small class="text-secondary">Загальна площа</small>
                                <div class="fw-bold">@filteredOrders.Sum(o => o.SquareMeters).ToString("N0") м²</div>
                            </div>
                            <div class="col">
                                <small class="text-secondary">Виробничих днів</small>
                                <div class="fw-bold">@filteredOrders.Sum(o => o.ProductionDuration).ToString("F1")</div>
                            </div>
                            <div class="col">
                                <small class="text-secondary">В роботі</small>
                                <div class="fw-bold text-success">@filteredOrders.Count(o => o.GetStatus(filterDate) == "В роботі")</div>
                            </div>
                            <div class="col">
                                <small class="text-secondary">Очікують</small>
                                <div class="fw-bold text-warning">@filteredOrders.Count(o => o.GetStatus(filterDate) == "Очікує")</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    }
    
    @if (!GetFilteredWorkshops().Any(w => GetSchedule(w.Number)?.Orders.Any() == true))
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Немає замовлень за обраними фільтрами
        </div>
    }
}

@code {
    private WorkshopData workshopData = new();
    private List<WorkshopConfig> workshops = new();
    private Dictionary<int, ProductionSchedule> schedules = new();
    
    private bool isLoading = true;
    private bool hasSchedules = false;
    private bool dragDropEnabled = true;
    
    // Дублікати
    private bool hasDuplicates = false;
    private int duplicateCount = 0;
    
    // Фільтри
    private string orderFilter = "all";
    private int selectedWorkshop = 0;
    private string searchQuery = "";
    private DateTime filterDate = DateTime.Today;
    
    // Редагування
    private Order? editingOrder;
    private string editOrderName = "";
    private string EditOrderDateValue { get; set; } = "";
    private string EditProductionStartValue { get; set; } = "";
    private string EditProductionEndValue { get; set; } = "";
    private string EditCompletionDateValue { get; set; } = "";
    private double editSquareMeters = 0;
    
    private DotNetObjectReference<Orders>? dotNetHelper;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (dragDropEnabled && hasSchedules)
        {
            await Task.Delay(100);
            await InitializeDragDropAsync();
        }
    }

    private async Task LoadData()
    {
        isLoading = true;
        
        try
        {
            workshops = await WorkshopConfigService.GetActiveWorkshopsAsync();
            workshopData = await StorageService.LoadWorkshopDataAsync();
            
            // Перевірка на дублікати
            CheckForDuplicates();
            
            if (workshopData.WorkshopOrders.Any())
            {
                foreach (var workshop in workshops)
                {
                    if (workshopData.WorkshopOrders.ContainsKey(workshop.Number))
                    {
                        var schedule = CalculateScheduleForWorkshop(workshop.Number);
                        if (schedule != null)
                        {
                            schedules[workshop.Number] = schedule;
                        }
                    }
                }
                hasSchedules = schedules.Any();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError("Помилка завантаження даних", ex, "Orders");
        }
        finally
        {
            isLoading = false;
        }
    }
    
    private void CheckForDuplicates()
    {
        duplicateCount = 0;
        
        // Збираємо всі унікальні замовлення (по площі + даті + назві)
        var allOrders = new List<(int workshop, double square, DateTime date, string name)>();
        
        foreach (var kvp in workshopData.WorkshopOrders)
        {
            var workshopNum = kvp.Key;
            var squares = kvp.Value;
            var dates = workshopData.WorkshopOrderDates.GetValueOrDefault(workshopNum) ?? new List<DateTime>();
            var names = workshopData.WorkshopOrderNames.GetValueOrDefault(workshopNum) ?? new List<string>();
            
            for (int i = 0; i < squares.Count; i++)
            {
                var date = i < dates.Count ? dates[i] : workshopData.StartDate;
                var name = i < names.Count ? names[i] : "";
                allOrders.Add((workshopNum, squares[i], date, name));
            }
        }
        
        // Знаходимо дублікати (однакова площа + дата + назва в різних цехах)
        var grouped = allOrders
            .GroupBy(o => (o.square, o.date, o.name))
            .Where(g => g.Count() > 1 && g.Select(x => x.workshop).Distinct().Count() > 1);
        
        duplicateCount = grouped.Sum(g => g.Count() - 1);
        hasDuplicates = duplicateCount > 0;
        
        if (hasDuplicates)
        {
            Logger.LogWarning($"Знайдено {duplicateCount} дублікатів замовлень", "Orders");
        }
    }
    
    private async Task CleanupDuplicates()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", 
            $"Видалити {duplicateCount} дублікатів замовлень? Залишиться тільки перше входження в кожному цеху.");
        if (!confirmed) return;
        
        try
        {
            await BackupService.CreateBackupAsync("Очищення дублікатів");
            
            // Збираємо унікальні замовлення
            var seenOrders = new HashSet<(double square, DateTime date, string name)>();
            var toRemove = new Dictionary<int, List<int>>(); // workshop -> list of indices to remove
            
            foreach (var kvp in workshopData.WorkshopOrders)
            {
                var workshopNum = kvp.Key;
                var squares = kvp.Value;
                var dates = workshopData.WorkshopOrderDates.GetValueOrDefault(workshopNum) ?? new List<DateTime>();
                var names = workshopData.WorkshopOrderNames.GetValueOrDefault(workshopNum) ?? new List<string>();
                
                toRemove[workshopNum] = new List<int>();
                
                for (int i = 0; i < squares.Count; i++)
                {
                    var date = i < dates.Count ? dates[i] : workshopData.StartDate;
                    var name = i < names.Count ? names[i] : "";
                    var key = (squares[i], date, name);
                    
                    if (seenOrders.Contains(key))
                    {
                        toRemove[workshopNum].Add(i);
                    }
                    else
                    {
                        seenOrders.Add(key);
                    }
                }
            }
            
            // Видаляємо дублікати (з кінця щоб індекси не зсувались)
            int removedCount = 0;
            foreach (var kvp in toRemove)
            {
                var workshopNum = kvp.Key;
                foreach (var index in kvp.Value.OrderByDescending(i => i))
                {
                    if (index < workshopData.WorkshopOrders[workshopNum].Count)
                        workshopData.WorkshopOrders[workshopNum].RemoveAt(index);
                    
                    if (workshopData.WorkshopOrderDates.ContainsKey(workshopNum) && 
                        index < workshopData.WorkshopOrderDates[workshopNum].Count)
                        workshopData.WorkshopOrderDates[workshopNum].RemoveAt(index);
                    
                    if (workshopData.WorkshopOrderNames.ContainsKey(workshopNum) && 
                        index < workshopData.WorkshopOrderNames[workshopNum].Count)
                        workshopData.WorkshopOrderNames[workshopNum].RemoveAt(index);
                    
                    removedCount++;
                }
            }
            
            workshopData.LastUpdated = DateTime.UtcNow;
            await StorageService.SaveWorkshopDataAsync(workshopData);
            
            await LoadData();
            
            await JSRuntime.InvokeVoidAsync("DragDropInterop.showToast", 
                $"Видалено {removedCount} дублікатів!", "success");
        }
        catch (Exception ex)
        {
            Logger.LogError("Помилка очищення дублікатів", ex, "Orders");
            await JSRuntime.InvokeVoidAsync("DragDropInterop.showToast", 
                $"Помилка: {ex.Message}", "error");
        }
    }

    private ProductionSchedule? CalculateScheduleForWorkshop(int workshopNumber)
    {
        if (!workshopData.WorkshopOrders.ContainsKey(workshopNumber) || 
            !workshopData.WorkshopOrders[workshopNumber].Any())
        {
            return null;
        }

        var orders = workshopData.WorkshopOrders[workshopNumber];
        
        var dates = workshopData.WorkshopOrderDates.ContainsKey(workshopNumber)
            ? workshopData.WorkshopOrderDates[workshopNumber]
            : orders.Select((_, i) => workshopData.StartDate.AddDays(i)).ToList();

        var names = workshopData.WorkshopOrderNames.GetValueOrDefault(workshopNumber);

        var capacity = workshopData.GetCapacity(workshopNumber);
        var leadTime = workshopData.GetProductionLeadTime(workshopNumber);
        var daysBefore = workshopData.GetDaysBeforeProduction(workshopNumber);

        var schedule = PlanningService.CalculateSchedule(
            orders,
            workshopData.StartDate,
            capacity,
            leadTime,
            dates,
            names,
            workshopData.CustomCompletionDates,
            workshopNumber,
            daysBefore
        );

        foreach (var order in schedule.Orders)
        {
            order.WorkshopNumber = workshopNumber;
        }

        return schedule;
    }

    private async Task InitializeDragDropAsync()
    {
        try
        {
            dotNetHelper ??= DotNetObjectReference.Create(this);
            
            foreach (var workshop in workshops)
            {
                if (schedules.ContainsKey(workshop.Number) && schedules[workshop.Number].Orders.Any())
                {
                    var elementId = $"orders-table-{workshop.Number}";
                    await JSRuntime.InvokeAsync<bool>(
                        "DragDropInterop.initSortable",
                        elementId,
                        dotNetHelper,
                        workshop.Number
                    );
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning($"Drag & Drop: {ex.Message}", "Orders");
        }
    }

    private ProductionSchedule? GetSchedule(int workshopNumber)
    {
        return schedules.GetValueOrDefault(workshopNumber);
    }

    private IEnumerable<WorkshopConfig> GetFilteredWorkshops()
    {
        if (selectedWorkshop == 0)
            return workshops.OrderBy(w => w.SortOrder);
        return workshops.Where(w => w.Number == selectedWorkshop);
    }

    private IEnumerable<Order> FilterOrders(List<Order> orders, int workshopNumber)
    {
        var result = orders.AsEnumerable();
        
        result = orderFilter switch
        {
            "in-production" => result.Where(o => o.GetStatus(filterDate) == "В роботі"),
            "not-started" => result.Where(o => o.GetStatus(filterDate) == "Очікує"),
            "completed" => result.Where(o => o.GetStatus(filterDate) == "Завершено"),
            _ => result
        };
        
        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            result = result.Where(o => 
                (o.OrderName?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                o.Day.ToString().Contains(searchQuery));
        }
        
        return result;
    }

    private int GetTotalOrdersCount() => schedules.Values.Sum(s => s.Orders.Count);
    private int GetInProductionCount() => schedules.Values.SelectMany(s => s.Orders).Count(o => o.GetStatus(filterDate) == "В роботі");
    private int GetNotStartedCount() => schedules.Values.SelectMany(s => s.Orders).Count(o => o.GetStatus(filterDate) == "Очікує");
    private int GetCompletedCount() => schedules.Values.SelectMany(s => s.Orders).Count(o => o.GetStatus(filterDate) == "Завершено");

    private void StartOrderEdit(int workshopNumber, Order order)
    {
        editingOrder = order;
        editingOrder.WorkshopNumber = workshopNumber;
        editOrderName = order.OrderName ?? "";
        EditOrderDateValue = order.StartDate.ToString("yyyy-MM-dd");
        EditProductionStartValue = order.ProductionStartDate.ToString("yyyy-MM-dd");
        EditProductionEndValue = order.ProductionEndDate.ToString("yyyy-MM-dd");
        EditCompletionDateValue = order.CompletionDate.ToString("yyyy-MM-dd");
        editSquareMeters = order.SquareMeters;
    }

    private void CancelOrderEdit()
    {
        editingOrder = null;
        editOrderName = "";
    }

    private async Task SaveOrderEdit(int workshopNumber, Order order)
    {
        try
        {
            await BackupService.CreateBackupAsync($"Редагування замовлення №{order.Day}");
            
            // order.Day - це 1-based номер в розрахованому графіку
            // Знаходимо індекс цього замовлення в schedule.Orders
            var schedule = GetSchedule(workshopNumber);
            if (schedule == null) 
            {
                Logger.LogWarning($"Schedule not found for workshop {workshopNumber}", "Orders");
                return;
            }
            
            // Шукаємо індекс замовлення в списку schedule.Orders
            var orderIndex = schedule.Orders.FindIndex(o => o.Day == order.Day);
            if (orderIndex < 0) 
            {
                Logger.LogWarning($"Order with Day={order.Day} not found in schedule", "Orders");
                return;
            }
            
            // Перевіряємо чи індекс в межах WorkshopOrders
            if (!workshopData.WorkshopOrders.ContainsKey(workshopNumber) ||
                orderIndex >= workshopData.WorkshopOrders[workshopNumber].Count)
            {
                Logger.LogWarning($"Invalid orderIndex {orderIndex} for workshop {workshopNumber}", "Orders");
                return;
            }
            
            var index = orderIndex;
            
            // === ОНОВЛЮЄМО НАЗВУ ===
            if (!workshopData.WorkshopOrderNames.ContainsKey(workshopNumber))
            {
                // Створюємо список назв такої ж довжини як WorkshopOrders
                var ordersCount = workshopData.WorkshopOrders[workshopNumber].Count;
                workshopData.WorkshopOrderNames[workshopNumber] = new List<string>(new string[ordersCount]);
            }
            
            // Розширюємо якщо потрібно
            while (workshopData.WorkshopOrderNames[workshopNumber].Count < workshopData.WorkshopOrders[workshopNumber].Count)
            {
                workshopData.WorkshopOrderNames[workshopNumber].Add("");
            }
            
            if (index < workshopData.WorkshopOrderNames[workshopNumber].Count)
            {
                workshopData.WorkshopOrderNames[workshopNumber][index] = editOrderName ?? "";
            }

            // === ОНОВЛЮЄМО ДАТУ ЗАМОВЛЕННЯ ===
            if (DateTime.TryParse(EditOrderDateValue, out var newOrderDate))
            {
                if (workshopData.WorkshopOrderDates.ContainsKey(workshopNumber) &&
                    index < workshopData.WorkshopOrderDates[workshopNumber].Count)
                {
                    workshopData.WorkshopOrderDates[workshopNumber][index] = newOrderDate;
                }
            }

            // === ОНОВЛЮЄМО ПЛОЩУ ===
            if (editSquareMeters > 0)
            {
                workshopData.WorkshopOrders[workshopNumber][index] = editSquareMeters;
            }

            // === ОНОВЛЮЄМО ДАТУ ЗАВЕРШЕННЯ ===
            if (DateTime.TryParse(EditCompletionDateValue, out var newCompletionDate))
            {
                var orderKey = $"{workshopNumber}_{order.Day}";
                workshopData.CustomCompletionDates[orderKey] = newCompletionDate;
            }

            workshopData.LastUpdated = DateTime.UtcNow;
            await StorageService.SaveWorkshopDataAsync(workshopData);
            
            // Перераховуємо графік
            var newSchedule = CalculateScheduleForWorkshop(workshopNumber);
            if (newSchedule != null)
            {
                schedules[workshopNumber] = newSchedule;
            }

            CancelOrderEdit();
            await JSRuntime.InvokeVoidAsync("DragDropInterop.showToast", "Замовлення збережено!", "success");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError($"Помилка збереження: {ex.Message}", ex, "Orders");
            await JSRuntime.InvokeVoidAsync("DragDropInterop.showToast", $"Помилка: {ex.Message}", "error");
        }
    }

    private async Task DeleteOrder(int workshopNumber, int orderDay)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Видалити замовлення №{orderDay}?");
        if (!confirmed) return;

        try
        {
            await BackupService.CreateBackupAsync($"Видалення замовлення №{orderDay}");
            
            // Знаходимо правильний індекс через schedule
            var schedule = GetSchedule(workshopNumber);
            if (schedule == null) return;
            
            var orderIndex = schedule.Orders.FindIndex(o => o.Day == orderDay);
            if (orderIndex < 0) return;
            
            var index = orderIndex;
            
            if (workshopData.WorkshopOrders.ContainsKey(workshopNumber) && index < workshopData.WorkshopOrders[workshopNumber].Count)
            {
                workshopData.WorkshopOrders[workshopNumber].RemoveAt(index);
            }
            if (workshopData.WorkshopOrderDates.ContainsKey(workshopNumber) && index < workshopData.WorkshopOrderDates[workshopNumber].Count)
            {
                workshopData.WorkshopOrderDates[workshopNumber].RemoveAt(index);
            }
            if (workshopData.WorkshopOrderNames.ContainsKey(workshopNumber) && index < workshopData.WorkshopOrderNames[workshopNumber].Count)
            {
                workshopData.WorkshopOrderNames[workshopNumber].RemoveAt(index);
            }

            workshopData.LastUpdated = DateTime.UtcNow;
            await StorageService.SaveWorkshopDataAsync(workshopData);
            
            var newSchedule = CalculateScheduleForWorkshop(workshopNumber);
            if (newSchedule != null)
            {
                schedules[workshopNumber] = newSchedule;
            }

            await JSRuntime.InvokeVoidAsync("DragDropInterop.showToast", "Замовлення видалено!", "success");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError("Помилка видалення", ex, "Orders");
        }
    }

    [JSInvokable]
    public async Task OnOrderReordered(int workshopNumber, int oldIndex, int newIndex)
    {
        try
        {
            Logger.LogInfo($"OnOrderReordered: workshop={workshopNumber}, old={oldIndex}, new={newIndex}", "Orders");
            
            if (!workshopData.WorkshopOrders.ContainsKey(workshopNumber))
            {
                Logger.LogWarning($"Workshop {workshopNumber} not found in WorkshopOrders", "Orders");
                return;
            }
            
            var orders = workshopData.WorkshopOrders[workshopNumber];
            
            // Перевіряємо межі
            if (oldIndex < 0 || oldIndex >= orders.Count || newIndex < 0 || newIndex >= orders.Count)
            {
                Logger.LogWarning($"Invalid indices: old={oldIndex}, new={newIndex}, count={orders.Count}", "Orders");
                return;
            }
            
            await BackupService.CreateBackupAsync($"Зміна порядку в цеху №{workshopNumber}");
            
            // Переміщуємо замовлення (площу)
            var orderValue = orders[oldIndex];
            orders.RemoveAt(oldIndex);
            orders.Insert(newIndex, orderValue);
            
            // Переміщуємо дати
            if (workshopData.WorkshopOrderDates.ContainsKey(workshopNumber))
            {
                var dates = workshopData.WorkshopOrderDates[workshopNumber];
                if (oldIndex < dates.Count && newIndex <= dates.Count)
                {
                    var dateValue = dates[oldIndex];
                    dates.RemoveAt(oldIndex);
                    dates.Insert(Math.Min(newIndex, dates.Count), dateValue);
                }
            }
            
            // Переміщуємо назви
            if (workshopData.WorkshopOrderNames.ContainsKey(workshopNumber))
            {
                var names = workshopData.WorkshopOrderNames[workshopNumber];
                if (oldIndex < names.Count && newIndex <= names.Count)
                {
                    var nameValue = names[oldIndex];
                    names.RemoveAt(oldIndex);
                    names.Insert(Math.Min(newIndex, names.Count), nameValue);
                }
            }
            
            workshopData.LastUpdated = DateTime.UtcNow;
            await StorageService.SaveWorkshopDataAsync(workshopData);
            
            // Перераховуємо графік
            var newSchedule = CalculateScheduleForWorkshop(workshopNumber);
            if (newSchedule != null)
            {
                schedules[workshopNumber] = newSchedule;
            }
            
            await JSRuntime.InvokeVoidAsync("DragDropInterop.showToast", "Порядок збережено!", "success");
            await InvokeAsync(StateHasChanged);
            
            Logger.LogInfo($"Order reordered successfully", "Orders");
        }
        catch (Exception ex)
        {
            Logger.LogError($"Помилка зміни порядку: {ex.Message}", ex, "Orders");
            await JSRuntime.InvokeVoidAsync("DragDropInterop.showToast", $"Помилка: {ex.Message}", "error");
        }
    }

    public void Dispose()
    {
        dotNetHelper?.Dispose();
    }
