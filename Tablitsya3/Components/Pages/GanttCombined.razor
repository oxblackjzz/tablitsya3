</style>

@code {
    private WorkshopData workshopData = new();
    private List<WorkshopConfig> workshops = new();
    private List<Order> allOrders = new();
    private List<DateTime> calendarDays = new();
    private Dictionary<int, int> workshopCapacities = new();
    private bool isLoading = true;
    private DotNetObjectReference<GanttCombined>? dotNetHelper;
    
    // Reorder modal state
    private bool isReorderModalVisible = false;
    private int reorderWorkshopNumber = 0;
    private string reorderWorkshopName = "";
    private string reorderWorkshopColor = "#3498db";
    private List<ReorderModal.ReorderItem>? reorderOrders;

    protected override async Task OnInitializedAsync()
    {
        UndoRedo.OnStateChanged += OnUndoRedoStateChanged;
        await LoadData();
    }
    
    private void OnUndoRedoStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!isLoading && allOrders.Any())
        {
            await InitializeDragDropAsync();
        }
    }

    private async Task InitializeDragDropAsync()
    {
        try
        {
            dotNetHelper ??= DotNetObjectReference.Create(this);
            
            foreach (var workshop in workshops)
            {
                var workshopOrders = allOrders.Where(o => o.WorkshopNumber == workshop.Number).ToList();
                if (!workshopOrders.Any()) continue;
                
                var elementId = $"gantt-workshop-{workshop.Number}";
                await JSRuntime.InvokeVoidAsync("GanttDragDrop.initGanttSortable", elementId, dotNetHelper, workshop.Number);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning($"Drag & Drop init: {ex.Message}", "GanttCombined");
        }
    }

    private async Task LoadData()
    {
        isLoading = true;
        StateHasChanged();
        
        try
        {
            workshops = await WorkshopConfigService.GetActiveWorkshopsAsync();
            workshopData = await StorageService.LoadWorkshopDataAsync();
            
            allOrders.Clear();
            workshopCapacities.Clear();
            
            foreach (var workshop in workshops)
            {
                if (!workshopData.WorkshopOrders.ContainsKey(workshop.Number)) continue;
                
                var orders = workshopData.WorkshopOrders[workshop.Number];
                var dates = workshopData.WorkshopOrderDates.GetValueOrDefault(workshop.Number) 
                    ?? orders.Select((_, i) => workshopData.StartDate.AddDays(i)).ToList();
                var names = workshopData.WorkshopOrderNames.GetValueOrDefault(workshop.Number);
                
                var capacity = workshopData.GetCapacity(workshop.Number);
                var leadTime = workshopData.GetProductionLeadTime(workshop.Number);
                var daysBefore = workshopData.GetDaysBeforeProduction(workshop.Number);
                
                workshopCapacities[workshop.Number] = capacity;
                
                var schedule = PlanningService.CalculateSchedule(
                    orders, workshopData.StartDate, capacity, leadTime,
                    dates, names, workshopData.CustomCompletionDates, workshop.Number, daysBefore
                );
                
                foreach (var order in schedule.Orders)
                {
                    order.WorkshopNumber = workshop.Number;
                    allOrders.Add(order);
                }
            }
            
            // Визначаємо діапазон дат
            if (allOrders.Any())
            {
                var minDate = allOrders.Min(o => o.ProductionStartDate).Date;
                var maxDate = allOrders.Max(o => o.CompletionDate).Date.AddDays(2);
                
                calendarDays = Enumerable.Range(0, (maxDate - minDate).Days + 1)
                    .Select(i => minDate.AddDays(i))
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError("Помилка завантаження", ex, "CombinedGantt");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnGanttOrderReordered(int workshopNumber, int oldIndex, int newIndex)
    {
        try
        {
            Logger.LogInfo($"OnGanttOrderReordered: workshop={workshopNumber}, old={oldIndex}, new={newIndex}", "GanttCombined");
            
            if (!workshopData.WorkshopOrders.ContainsKey(workshopNumber)) 
            {
                Logger.LogWarning($"Workshop {workshopNumber} not found", "GanttCombined");
                return;
            }
            
            var orders = workshopData.WorkshopOrders[workshopNumber];
            if (oldIndex < 0 || oldIndex >= orders.Count || newIndex < 0 || newIndex >= orders.Count) 
            {
                Logger.LogWarning($"Invalid indices: old={oldIndex}, new={newIndex}, count={orders.Count}", "GanttCombined");
                return;
            }
            
            // Зберігаємо стан для Undo
            var workshopName = workshops.FirstOrDefault(w => w.Number == workshopNumber)?.Name ?? $"Цех {workshopNumber}";
            UndoRedo.SaveState(workshopData, $"Зміна порядку в {workshopName}");
            
            // Переміщуємо замовлення (площу)
            var orderValue = orders[oldIndex];
            orders.RemoveAt(oldIndex);
            orders.Insert(newIndex, orderValue);
            
            // Переміщуємо дати
            if (workshopData.WorkshopOrderDates.ContainsKey(workshopNumber))
            {
                var dates = workshopData.WorkshopOrderDates[workshopNumber];
                if (oldIndex < dates.Count && newIndex <= dates.Count)
                {
                    var dateValue = dates[oldIndex];
                    dates.RemoveAt(oldIndex);
                    dates.Insert(Math.Min(newIndex, dates.Count), dateValue);
                }
            }
            
            // Переміщуємо назви
            if (workshopData.WorkshopOrderNames.ContainsKey(workshopNumber))
            {
                var names = workshopData.WorkshopOrderNames[workshopNumber];
                if (oldIndex < names.Count && newIndex <= names.Count)
                {
                    var nameValue = names[oldIndex];
                    names.RemoveAt(oldIndex);
                    names.Insert(Math.Min(newIndex, names.Count), nameValue);
                }
            }
            
            workshopData.LastUpdated = DateTime.UtcNow;
            await StorageService.SaveWorkshopDataAsync(workshopData);
            await LoadData();
            
            await JSRuntime.InvokeVoidAsync("DragDropInterop.showToast", "Порядок змінено!", "success");
            await InvokeAsync(StateHasChanged);
            
            Logger.LogInfo("Order reordered successfully", "GanttCombined");
        }
        catch (Exception ex)
        {
            Logger.LogError($"Помилка зміни порядку: {ex.Message}", ex, "GanttCombined");
            await JSRuntime.InvokeVoidAsync("DragDropInterop.showToast", $"Помилка: {ex.Message}", "error");
        }
    }

    [JSInvokable]
    public async Task OnGanttOrderTransfer(int fromWorkshop, int toWorkshop, int orderDay, double squareMeters)
    {
        try
        {
            Logger.LogInfo($"OnGanttOrderTransfer: from={fromWorkshop}, to={toWorkshop}, day={orderDay}, square={squareMeters}", "GanttCombined");
            
            if (!workshopData.WorkshopOrders.ContainsKey(fromWorkshop)) 
            {
                Logger.LogWarning($"Source workshop {fromWorkshop} not found", "GanttCombined");
                return;
            }
            
            var fromOrders = workshopData.WorkshopOrders[fromWorkshop];
            
            // orderDay = 1-based index в списку замовлень цеху
            // Але після сортування може не відповідати реальному індексу
            // Тому шукаємо по комбінації squareMeters + приблизна позиція
            var orderIndex = orderDay - 1;
            
            // Перевіряємо чи індекс валідний і площа співпадає
            if (orderIndex < 0 || orderIndex >= fromOrders.Count)
            {
                // Шукаємо по площі
                orderIndex = -1;
                for (int i = 0; i < fromOrders.Count; i++)
                {
                    if (Math.Abs(fromOrders[i] - squareMeters) < 0.01)
                    {
                        orderIndex = i;
                        break;
                    }
                }
            }
            else if (Math.Abs(fromOrders[orderIndex] - squareMeters) > 0.01)
            {
                // Індекс є але площа не співпадає - шукаємо по площі
                for (int i = 0; i < fromOrders.Count; i++)
                {
                    if (Math.Abs(fromOrders[i] - squareMeters) < 0.01)
                    {
                        orderIndex = i;
                        break;
                    }
                }
            }
            
            if (orderIndex < 0 || orderIndex >= fromOrders.Count) 
            {
                Logger.LogWarning($"Order not found: day={orderDay}, square={squareMeters}", "GanttCombined");
                return;
            }
            
            // Зберігаємо стан для Undo
            var fromName = workshops.FirstOrDefault(w => w.Number == fromWorkshop)?.Name ?? $"Цех {fromWorkshop}";
            var toName = workshops.FirstOrDefault(w => w.Number == toWorkshop)?.Name ?? $"Цех {toWorkshop}";
            UndoRedo.SaveState(workshopData, $"Переміщення з {fromName} до {toName}");
            
            // Зберігаємо оригінальний цех (якщо ще не збережено)
            var originalKey = $"{fromWorkshop}_{orderIndex + 1}";
            int originalWorkshop = fromWorkshop;
            if (workshopData.OriginalWorkshops.ContainsKey(originalKey))
            {
                originalWorkshop = workshopData.OriginalWorkshops[originalKey];
                workshopData.OriginalWorkshops.Remove(originalKey);
            }
            
            // Видаляємо з вихідного цеху
            var orderValue = fromOrders[orderIndex];
            fromOrders.RemoveAt(orderIndex);
            
            DateTime? orderDate = null;
            if (workshopData.WorkshopOrderDates.ContainsKey(fromWorkshop) && 
                orderIndex < workshopData.WorkshopOrderDates[fromWorkshop].Count)
            {
                orderDate = workshopData.WorkshopOrderDates[fromWorkshop][orderIndex];
                workshopData.WorkshopOrderDates[fromWorkshop].RemoveAt(orderIndex);
            }
            
            string orderName = "";
            if (workshopData.WorkshopOrderNames.ContainsKey(fromWorkshop) && 
                orderIndex < workshopData.WorkshopOrderNames[fromWorkshop].Count)
            {
                orderName = workshopData.WorkshopOrderNames[fromWorkshop][orderIndex];
                workshopData.WorkshopOrderNames[fromWorkshop].RemoveAt(orderIndex);
            }
            
            // Додаємо до нового цеху
            if (!workshopData.WorkshopOrders.ContainsKey(toWorkshop))
                workshopData.WorkshopOrders[toWorkshop] = new List<double>();
            workshopData.WorkshopOrders[toWorkshop].Add(orderValue);
            
            // Зберігаємо оригінальний цех для нової позиції
            var newIndex = workshopData.WorkshopOrders[toWorkshop].Count;
            var newKey = $"{toWorkshop}_{newIndex}";
            workshopData.OriginalWorkshops[newKey] = originalWorkshop;
            
            if (orderDate.HasValue)
            {
                if (!workshopData.WorkshopOrderDates.ContainsKey(toWorkshop))
                    workshopData.WorkshopOrderDates[toWorkshop] = new List<DateTime>();
                workshopData.WorkshopOrderDates[toWorkshop].Add(orderDate.Value);
            }
            
            if (!string.IsNullOrEmpty(orderName))
            {
                if (!workshopData.WorkshopOrderNames.ContainsKey(toWorkshop))
                    workshopData.WorkshopOrderNames[toWorkshop] = new List<string>();
                workshopData.WorkshopOrderNames[toWorkshop].Add(orderName);
            }
            
            workshopData.LastUpdated = DateTime.UtcNow;
            await StorageService.SaveWorkshopDataAsync(workshopData);
            await LoadData();
            
            await JSRuntime.InvokeVoidAsync("DragDropInterop.showToast", $"Переміщено з {fromName} до {toName}", "success");
            
            Logger.LogInfo($"Order transferred successfully: {orderValue} м² from {fromName} to {toName}", "GanttCombined");
        }
        catch (Exception ex)
        {
            Logger.LogError($"Помилка переміщення: {ex.Message}", ex, "GanttCombined");
            await JSRuntime.InvokeVoidAsync("DragDropInterop.showToast", $"Помилка: {ex.Message}", "error");
        }
    }

    private string GetWorkshopColor(int workshopNumber)
    {
        var colors = new[] { "#e74c3c", "#3498db", "#27ae60", "#f39c12", "#9b59b6", "#1abc9c", "#e67e22", "#34495e" };
        return colors[(workshopNumber - 1) % colors.Length];
    }

    private string GetDayOfWeekShort(DateTime date)
    {
        return date.DayOfWeek switch
        {
            DayOfWeek.Monday => "Пн",
            DayOfWeek.Tuesday => "Вт",
            DayOfWeek.Wednesday => "Ср",
            DayOfWeek.Thursday => "Чт",
            DayOfWeek.Friday => "Пт",
            DayOfWeek.Saturday => "Сб",
            DayOfWeek.Sunday => "Нд",
            _ => ""
        };
    }
    
    // ========== Undo/Redo ==========[]
    
    private async Task PerformUndo()
    {
        var snapshot = UndoRedo.Undo(workshopData);
        if (snapshot != null)
        {
            snapshot.ApplyTo(workshopData);
            await StorageService.SaveWorkshopDataAsync(workshopData);
            await LoadData();
            await JSRuntime.InvokeVoidAsync("DragDropInterop.showToast", "Скасовано!", "info");
        }
    }
    
    private async Task PerformRedo()
    {
        var snapshot = UndoRedo.Redo(workshopData);
        if (snapshot != null)
        {
            snapshot.ApplyTo(workshopData);
            await StorageService.SaveWorkshopDataAsync(workshopData);
            await LoadData();
            await JSRuntime.InvokeVoidAsync("DragDropInterop.showToast", "Повторено!", "info");
        }
    }
    
    // ========== Reorder Modal =========
    
    private void OpenReorderModal(int workshopNumber, string workshopName, string color)
    {
        reorderWorkshopNumber = workshopNumber;
        reorderWorkshopName = workshopName;
        reorderWorkshopColor = color;
        
        // Підготовка списку замовлень для редагування
        if (workshopData.WorkshopOrders.ContainsKey(workshopNumber))
        {
            var orders = workshopData.WorkshopOrders[workshopNumber];
            var dates = workshopData.WorkshopOrderDates.GetValueOrDefault(workshopNumber) 
                ?? orders.Select((_, i) => workshopData.StartDate.AddDays(i)).ToList();
            var names = workshopData.WorkshopOrderNames.GetValueOrDefault(workshopNumber) 
                ?? orders.Select((_, i) => "").ToList();
            
            reorderOrders = new List<ReorderModal.ReorderItem>();
            for (int i = 0; i < orders.Count; i++)
            {
                reorderOrders.Add(new ReorderModal.ReorderItem
                {
                    SquareMeters = orders[i],
                    OrderDate = i < dates.Count ? dates[i] : workshopData.StartDate,
                    Name = i < names.Count ? names[i] : ""
                });
            }
        }
        else
        {
            reorderOrders = new List<ReorderModal.ReorderItem>();
        }
        
        isReorderModalVisible = true;
        StateHasChanged();
    }
    
    private void CloseReorderModal()
    {
        isReorderModalVisible = false;
        reorderOrders = null;
        StateHasChanged();
    }
    
    private async Task SaveReorderedOrders(List<ReorderModal.ReorderItem> orders)
    {
        if (!workshopData.WorkshopOrders.ContainsKey(reorderWorkshopNumber)) return;
        
        // Зберігаємо стан перед зміною
        UndoRedo.SaveState(workshopData, $"Зміна порядку в {reorderWorkshopName}");
        
        // Оновлюємо дані
        workshopData.WorkshopOrders[reorderWorkshopNumber] = orders.Select(o => o.SquareMeters).ToList();
        workshopData.WorkshopOrderDates[reorderWorkshopNumber] = orders.Select(o => o.OrderDate).ToList();
        workshopData.WorkshopOrderNames[reorderWorkshopNumber] = orders.Select(o => o.Name).ToList();
        
        workshopData.LastUpdated = DateTime.UtcNow;
        await StorageService.SaveWorkshopDataAsync(workshopData);
        
        isReorderModalVisible = false;
        await LoadData();
        
        await JSRuntime.InvokeVoidAsync("DragDropInterop.showToast", "Порядок змінено!", "success");
    }

    public void Dispose()
    {
        UndoRedo.OnStateChanged -= OnUndoRedoStateChanged;
        dotNetHelper?.Dispose();
    }
}
