@page "/access-denied"
@layout Tablitsya3.Components.Layout.EmptyLayout
@attribute [AllowAnonymous]

<PageTitle>Доступ заборонено</PageTitle>

<div class="denied-card">
    <div class="icon">🚫</div>
    <h1>Доступ заборонено</h1>
    <p>У вас немає прав для перегляду цієї сторінки.</p>
    <div class="actions">
        <a href="/" class="btn">На головну</a>
        <a href="/account/logout" class="btn btn-secondary">Вийти</a>
    </div>
</div>

<style>
    .denied-card {
        background: white;
        border-radius: 16px;
        padding: 50px 40px;
        max-width: 480px;
        width: 100%;
        text-align: center;
        box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }
    .denied-card .icon { font-size: 64px; margin-bottom: 16px; }
    .denied-card h1 { color: #dc3545; margin: 0 0 12px; }
    .denied-card p { color: #666; margin-bottom: 28px; }
    .denied-card .actions { display: flex; gap: 12px; justify-content: center; }
    .btn {
        padding: 10px 22px;
        border-radius: 8px;
        background: #0d6efd;
        color: white;
        text-decoration: none;
        font-weight: 600;
    }
    .btn-secondary { background: #6c757d; }
</style>
