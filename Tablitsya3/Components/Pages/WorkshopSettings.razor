@page "/workshop-settings"
@using Tablitsya3.Models
@using Tablitsya3.Services
@inject UnifiedStorageService StorageService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Налаштування цехів</PageTitle>

<h1 class="mb-4">
    <i class="bi bi-gear-fill"></i> Налаштування цехів
</h1>

<div class="row mb-4">
    <div class="col-12">
     <div class="alert alert-info">
     <i class="bi bi-info-circle-fill"></i>
            <strong>Інструкція:</strong> Встановіть продуктивність (од/день) для кожного цеху та загальні параметри планування.
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @statusMessage
      <button type="button" class="btn-close" @onclick="() => statusMessage = string.Empty"></button>
    </div>
}

<div class="row g-4 mb-4">
    <!-- Цех №1 -->
    <div class="col-md-4">
    <div class="card h-100 @(IsActiveWorkshop(1) ? "border-success" : "")">
        <div class="card-header bg-primary text-white">
       <h5 class="mb-0"><i class="bi bi-building"></i> Цех №1</h5>
     </div>
       <div class="card-body">
         <label class="form-label fw-bold">Продуктивність (од/день):</label>
   <input type="number" class="form-control form-control-lg" @bind="workshop1Capacity" min="100" max="10000" step="100" />
          <small class="text-muted">Рекомендовано: 800-1200 од/день</small>
   </div>
        </div>
    </div>

    <!-- Цех №3 -->
    <div class="col-md-4">
   <div class="card h-100 @(IsActiveWorkshop(3) ? "border-success" : "")">
         <div class="card-header bg-success text-white">
              <h5 class="mb-0"><i class="bi bi-building"></i> Цех №3</h5>
   </div>
 <div class="card-body">
        <label class="form-label fw-bold">Продуктивність (од/день):</label>
           <input type="number" class="form-control form-control-lg" @bind="workshop3Capacity" min="100" max="10000" step="100" />
    <small class="text-muted">Рекомендовано: 800-1200 од/день</small>
        </div>
     </div>
    </div>

    <!-- Цех №6 -->
    <div class="col-md-4">
        <div class="card h-100 @(IsActiveWorkshop(6) ? "border-success" : "")">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="bi bi-building"></i> Цех №6</h5>
          </div>
       <div class="card-body">
                <label class="form-label fw-bold">Продуктивність (од/день):</label>
             <input type="number" class="form-control form-control-lg" @bind="workshop6Capacity" min="100" max="10000" step="100" />
           <small class="text-muted">Рекомендовано: 800-1200 од/день</small>
</div>
        </div>
    </div>
</div>

<!-- Загальні налаштування -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card border-info">
     <div class="card-header bg-info text-white">
      <h5 class="mb-0"><i class="bi bi-sliders"></i> Загальні параметри планування</h5>
        </div>
    <div class="card-body">
          <div class="row g-3">
 <div class="col-md-4">
                  <label class="form-label fw-bold">Тривалість виробництва (днів):</label>
       <input type="number" class="form-control" @bind="productionLeadTime" min="1" max="30" />
    <small class="text-muted">Скільки днів потрібно на виготовлення партії</small>
    </div>
  <div class="col-md-4">
        <label class="form-label fw-bold">Днів до початку виробництва:</label>
         <input type="number" class="form-control" @bind="daysBeforeProduction" min="0" max="10" />
               <small class="text-muted">Підготовка перед початком виробництва</small>
     </div>
     <div class="col-md-4">
          <label class="form-label fw-bold">Дата початку планування:</label>
      <input type="date" class="form-control" @bind="startDate" />
       <small class="text-muted">Від якої дати починати розрахунки</small>
  </div>
      </div>
     </div>
        </div>
    </div>
</div>

<!-- Кнопки управління -->
<div class="row mb-4">
    <div class="col-12">
        <div class="d-flex gap-2">
            <button class="btn btn-primary btn-lg" @onclick="SaveSettings" disabled="@isSaving">
    <i class="bi bi-save-fill"></i> @(isSaving ? "Збереження..." : "Зберегти налаштування")
   </button>
            <button class="btn btn-secondary btn-lg" @onclick="LoadSettings">
<i class="bi bi-arrow-clockwise"></i> Скинути зміни
       </button>
      <button class="btn btn-outline-primary btn-lg" @onclick="GoToPlanning">
     <i class="bi bi-calendar-check-fill"></i> До планування
       </button>
      </div>
    </div>
</div>

@code {
    private int workshop1Capacity = 1000;
    private int workshop3Capacity = 1000;
    private int workshop6Capacity = 1000;
    private int productionLeadTime = 5;
    private int daysBeforeProduction = 1;
    private DateTime startDate = new DateTime(2025, 1, 1);
  private bool isSaving = false;
 private string statusMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
     await LoadSettings();
    }

    private async Task LoadSettings()
    {
        try
        {
        var data = await StorageService.LoadWorkshopDataAsync();
      if (data != null)
    {
    workshop1Capacity = data.WorkshopCapacities.ContainsKey(1) ? data.WorkshopCapacities[1] : 1000;
      workshop3Capacity = data.WorkshopCapacities.ContainsKey(3) ? data.WorkshopCapacities[3] : 1000;
          workshop6Capacity = data.WorkshopCapacities.ContainsKey(6) ? data.WorkshopCapacities[6] : 1000;
       productionLeadTime = data.ProductionLeadTime;
             daysBeforeProduction = data.DaysBeforeProduction;
             startDate = data.StartDate;
  }
        }
     catch (Exception ex)
        {
            statusMessage = $"❌ Помилка завантаження: {ex.Message}";
        }
 }

    private async Task SaveSettings()
    {
        isSaving = true;
        statusMessage = string.Empty;

        try
        {
       var data = await StorageService.LoadWorkshopDataAsync() ?? new WorkshopData();

   data.WorkshopCapacities[1] = workshop1Capacity;
    data.WorkshopCapacities[3] = workshop3Capacity;
  data.WorkshopCapacities[6] = workshop6Capacity;
          data.ProductionLeadTime = productionLeadTime;
        data.DaysBeforeProduction = daysBeforeProduction;
        data.StartDate = startDate;

  await StorageService.SaveWorkshopDataAsync(data);

   statusMessage = "✅ Налаштування успішно збережено!";
      }
        catch (Exception ex)
        {
  statusMessage = $"❌ Помилка збереження: {ex.Message}";
        }
   finally
      {
 isSaving = false;
        }
    }

  private bool IsActiveWorkshop(int workshopNumber)
    {
     return workshopNumber switch
        {
            1 => workshop1Capacity > 0,
        3 => workshop3Capacity > 0,
            6 => workshop6Capacity > 0,
          _ => false
        };
  }

    private void GoToPlanning()
    {
        Navigation.NavigateTo("/production-planning");
    }
}
