@code {
    private Dictionary<int, int> workshopCapacities = new()
    {
        { 1, 1000 },
        { 3, 1000 },
        { 6, 1000 }
    };

    private int defaultCapacity = 1000;
    private int productionLeadTime = 5;
    private int daysBeforeProduction = 5;
    private bool isSaving = false;
    private bool isMigrating = false;
    private bool migrationCompleted = false;
    private string statusMessage = string.Empty;
    private DateTime? lastSaved = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadSettings();
        
    // ����������� ������� ��� ������� �����������
        try
        {
     var hasData = StorageService.HasSavedData();
            if (hasData)
            {
 // ����������� ��������� ������� ��� �������� ����� ���������
      await Task.Delay(500);
    await MigrateData();
        }
        }
        catch (Exception ex)
        {
       statusMessage = $"������� ����������� �������: {ex.Message}";
    }
    }

    private async Task LoadSettings()
    {
        try
      {
            var data = await StorageService.LoadWorkshopDataAsync();
    
            if (data?.WorkshopCapacities != null)
            {
              workshopCapacities = data.WorkshopCapacities;
         lastSaved = data.LastUpdated;
        productionLeadTime = data.ProductionLeadTime;
            daysBeforeProduction = data.DaysBeforeProduction;
            }
        }
        catch (Exception ex)
        {
   statusMessage = $"������� ������������ �����������: {ex.Message}";
   }
}

    private async Task MigrateData()
    {
        isMigrating = true;
        migrationCompleted = false;
        statusMessage = string.Empty;

        try
        {
            var success = await StorageService.MigrateDataEncodingAsync();
            
            if (success)
            {
      migrationCompleted = true;
     statusMessage = @"? ̳������ ��������� ������!

?? �� ���� ��������:
1. �������� ��������� ������� � ���� ���������
2. ��� ������������� � ���������� UTF-8 ����������
3. �������� �������� ���� (workshop-data.json.backup)

?? ������������: �������� �� ������� ""���������� �����������"" �� �������� ���������.";
    
     // ��������������� ������������
       await LoadSettings();
            }
  else
            {
     statusMessage = "?? ̳������ �� ��������: ��� ������ ��� ��� � ����������� ������.";
          }
        }
        catch (Exception ex)
        {
     statusMessage = $"? ������� �������: {ex.Message}";
        }
        finally
        {
 isMigrating = false;
  }
    }

    private async Task SaveSettings()
    {
      isSaving = true;
        statusMessage = string.Empty;

        try
 {
  // ��������
      foreach (var kvp in workshopCapacities)
       {
          if (kvp.Value < 100 || kvp.Value > 10000)
    {
   statusMessage = $"?? ��������� ���� �{kvp.Key} �� ���� � ����� 100-10,000 �?/����";
           return;
   }
        }
    
          // �������� productionLeadTime
          if (productionLeadTime < 1 || productionLeadTime > 60)
         {
           statusMessage = "?? ������ ���� ���������� �� ���� � ����� 1-60 ���";
                return;
         }
            
     // �������� daysBeforeProduction
            if (daysBeforeProduction < 0 || daysBeforeProduction > 30)
       {
    statusMessage = "?? �������� ������ �� ���� � ����� 0-30 ���";
           return;
 }

            var data = await StorageService.LoadWorkshopDataAsync() ?? new WorkshopData
   {
      WorkshopOrders = new()
                {
        { 1, new List<double>() },
    { 3, new List<double>() },
         { 6, new List<double>() }
         },
WorkshopOrderDates = new()
    {
          { 1, new List<DateTime>() },
            { 3, new List<DateTime>() },
          { 6, new List<DateTime>() }
  }
       };

          data.WorkshopCapacities = workshopCapacities;
       data.ProductionLeadTime = productionLeadTime;
    data.DaysBeforeProduction = daysBeforeProduction;
      data.LastUpdated = DateTime.Now;

       await StorageService.SaveWorkshopDataAsync(data);

            lastSaved = DateTime.Now;
       statusMessage = @"? ������������ ������ ��������! 
            
�� ������ ���:
1?? ���������� �� ������� ""���������� �����������""
