@page "/scanning"
@page "/scanning/{WorkstationId:int}"
@using Tablitsya3.Models.Scanning
@using Tablitsya3.Data.Entities
@using Tablitsya3.Services
@using Tablitsya3.Components.Shared
@inject ScanningService ScanningService
@inject WorkstationService WorkstationService
@inject DefectService DefectService
@inject LoggingService Logger
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Сканування деталей</PageTitle>

<div class="row">
    <!-- Панель працівника (ліва колонка) -->
    <div class="col-lg-3 mb-4">
        <!-- Вибір станції якщо не вказана в URL -->
        @if (WorkstationId == 0)
        {
            <div class="card mb-3">
                <div class="card-header bg-info text-white">
                    <i class="bi bi-pc-display-horizontal me-2"></i>Виберіть станцію
                </div>
                <div class="card-body">
                    <select class="form-select" @bind="selectedWorkstationId" @bind:after="OnWorkstationSelected">
                        <option value="0">-- Оберіть станцію --</option>
                        @foreach (var ws in workstations)
                        {
                            <option value="@ws.Id">@ws.Name (@ws.StageName)</option>
                        }
                    </select>
                    @if (!workstations.Any())
                    {
                        <div class="alert alert-warning mt-3 mb-0 py-2">
                            <small><i class="bi bi-exclamation-triangle me-1"></i>Немає станцій. <a href="/workstations">Створіть станцію</a></small>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Компонент авторизації працівника -->
        @if (selectedWorkstationId > 0)
        {
            <WorkerLogin WorkstationId="@selectedWorkstationId" 
                         OnAuthenticated="OnWorkerAuthenticated"
                         OnLoggedOut="OnWorkerLoggedOut"
                         @ref="workerLoginRef" />
        }

        <!-- Інформація про станцію -->
        @if (currentWorkstation != null)
        {
            <div class="card mt-3">
                <div class="card-header" style="background-color: @currentWorkstation.Stage.GetColor(); color: white;">
                    <i class="bi bi-@currentWorkstation.Stage.GetIcon() me-2"></i>@currentWorkstation.StageName
                </div>
                <div class="card-body py-2">
                    <small class="text-muted d-block">Станція: <strong>@currentWorkstation.Name</strong></small>
                    @if (!string.IsNullOrEmpty(currentWorkstation.Location))
                    {
                        <small class="text-muted d-block">Локація: @currentWorkstation.Location</small>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Основна панель -->
    <div class="col-lg-9">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="mb-1">
                    <i class="bi bi-qr-code-scan text-primary"></i> Сканування деталей
                </h1>
                <p class="text-secondary mb-0">
                    @if (workerContext != null)
                    {
                        <span class="badge bg-success me-2">
                            <i class="bi bi-person-check me-1"></i>@workerContext.WorkerName
                        </span>
                    }
                    Відстеження виробництва по етапах
                </p>
            </div>
            <div class="d-flex gap-2">
                @if (projects.Any())
                {
                    <select class="form-select" style="width: 250px;" @bind="selectedProjectUuid" @bind:after="OnProjectChanged">
                        <option value="">Всі проекти</option>
                        @foreach (var project in projects)
                        {
                            <option value="@project.ProjectUuid">@project.FileName (@project.PartsCount дет.)</option>
                        }
                    </select>
                }
                <a href="/scanning/import" class="btn btn-outline-primary">
                    <i class="bi bi-upload"></i> Імпорт
                </a>
                <button class="btn btn-primary" @onclick="LoadAllData">
                    <i class="bi bi-arrow-clockwise"></i> Оновити
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(scanMessage))
        {
            <div class="alert alert-@scanMessageClass alert-dismissible fade show mb-4" role="alert">
                <i class="bi bi-@scanMessageIcon me-2"></i>
                @scanMessage
                <button type="button" class="btn-close" @onclick="ClearScanMessage"></button>
            </div>
        }

        <!-- Шкала прогресу проекту -->
        @if (projectStatistics != null)
        {
            <div class="row mb-4">
                <div class="col-12">
                    <ProjectProgressCard Statistics="projectStatistics" 
                                         Title="@(string.IsNullOrEmpty(selectedProjectUuid) ? "Загальний прогрес" : $"Прогрес: {GetSelectedProjectName()}")"
                                         ShowLegend="true" />
                </div>
            </div>
        }

        <div class="row">
            <!-- Панель сканування -->
            <div class="col-lg-5 mb-4">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <i class="bi bi-qr-code"></i> Сканування
                    </div>
                    <div class="card-body">
                        @if (!CanScan)
                        {
                            <div class="alert alert-warning mb-0">
                                <i class="bi bi-lock me-2"></i>
                                @if (selectedWorkstationId == 0)
                                {
                                    <span>Виберіть станцію для початку роботи</span>
                                }
                                else if (workerContext == null && currentWorkstation?.RequiresWorkerAuth == true)
                                {
                                    <span>Авторизуйтесь для початку сканування</span>
                                }
                            </div>
                        }
                        else
                        {
                            <!-- Поле QR-коду -->
                            <div class="mb-3">
                                <label class="form-label">QR-код деталі</label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text"><i class="bi bi-upc-scan"></i></span>
                                    <input type="text" 
                                           class="form-control" 
                                           @bind="qrCode" 
                                           @bind:event="oninput"
                                           @onkeypress="OnQRKeyPress"
                                           placeholder="Відскануйте QR-код..."
                                           @ref="qrInput" />
                                    <button class="btn btn-outline-secondary" @onclick="ClearQR" title="Очистити">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </div>
                            </div>

                            <!-- Автоматичний режим для станції -->
                            @if (currentWorkstation != null)
                            {
                                <div class="mb-3">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="autoStageSwitch" @bind="useStationStage">
                                        <label class="form-check-label" for="autoStageSwitch">
                                            Автоматично: <strong style="color: @currentWorkstation.Stage.GetColor()">@currentWorkstation.StageName</strong>
                                        </label>
                                    </div>
                                </div>
                            }

                            <!-- Вибір етапу (якщо ручний режим) -->
                            @if (!useStationStage)
                            {
                                <div class="mb-3">
                                    <label class="form-label">Етап</label>
                                    <select class="form-select" @bind="selectedStage">
                                        <option value="">Автоматично</option>
                                        @foreach (ProductionStage stage in Enum.GetValues<ProductionStage>())
                                        {
                                            <option value="@stage">@stage.GetDisplayName()</option>
                                        }
                                    </select>
                                </div>
                            }

                            <!-- Кнопка сканування -->
                            <div class="d-flex gap-2">
                                <button class="btn btn-success btn-lg flex-grow-1" @onclick="ProcessScan" disabled="@(isScanning || string.IsNullOrEmpty(qrCode))">
                                    @if (isScanning)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                        <span>Обробка...</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-check-lg me-2"></i>
                                        <span>Сканувати</span>
                                    }
                                </button>
                                <button class="btn btn-danger btn-lg" @onclick="ShowDefectModal" disabled="@string.IsNullOrEmpty(qrCode)" title="Зареєструвати брак">
                                    <i class="bi bi-exclamation-triangle"></i>
                                </button>
                            </div>
                        }
                    </div>
                </div>

                <!-- Інформація про останню деталь -->
                @if (lastScannedPart != null)
                {
                    <div class="card mt-3">
                        <div class="card-header bg-success text-white">
                            <i class="bi bi-info-circle"></i> Остання деталь
                        </div>
                        <div class="card-body">
                            <h6 class="card-title mb-3">@lastScannedPart.Name</h6>
                            
                            <table class="table table-sm mb-3">
                                <tr>
                                    <td class="text-muted">Код:</td>
                                    <td><code>@lastScannedPart.Code</code></td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Розміри:</td>
                                    <td>@lastScannedPart.Dimensions мм</td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Замовлення:</td>
                                    <td>@lastScannedPart.OrderName</td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Прогрес:</td>
                                    <td>
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar bg-success" style="width: @(lastScannedPart.ProgressPercent)%">
                                                @lastScannedPart.ProgressPercent%
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            </table>

                            <!-- Етапи -->
                            <div class="d-flex gap-2 flex-wrap">
                                @foreach (ProductionStage stage in Enum.GetValues<ProductionStage>())
                                {
                                    var isRequired = lastScannedPart.IsStageRequired(stage);
                                    var isCompleted = lastScannedPart.IsStageCompleted(stage);
                                    var badgeClass = !isRequired ? "bg-secondary" : isCompleted ? "bg-success" : "bg-warning text-dark";
                                    
                                    <span class="badge @badgeClass">
                                        @if (isCompleted)
                                        {
                                            <i class="bi bi-check-lg me-1"></i>
                                        }
                                        @stage.GetDisplayName()
                                        @if (stage == ProductionStage.EdgeBanding && lastScannedPart.EdgeBandingSidesRequired > 0)
                                        {
                                            <span class="ms-1">(@lastScannedPart.EdgeBandingSidesCompleted/@lastScannedPart.EdgeBandingSidesRequired)</span>
                                        }
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Таблиця деталей -->
            <div class="col-lg-7">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-table"></i> Деталі</span>
                        <div class="d-flex gap-2 align-items-center">
                            <!-- Фільтр по файлу -->
                            <select class="form-select form-select-sm" style="width: 150px;" @bind="filterFileName" @bind:after="LoadData">
                                <option value="">Всі файли</option>
                                @foreach (var file in fileNames)
                                {
                                    <option value="@file">@file</option>
                                }
                            </select>

                            <!-- Фільтр по статусу -->
                            <select class="form-select form-select-sm" style="width: 120px;" @bind="filterCompleted" @bind:after="LoadData">
                                <option value="">Всі</option>
                                <option value="false">В роботі</option>
                                <option value="true">Завершені</option>
                            </select>

                            <span class="badge bg-primary">@totalParts</span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        @if (isLoading)
                        {
                            <div class="text-center py-5">
                                <div class="spinner-border text-primary"></div>
                                <p class="mt-2 text-muted">Завантаження...</p>
                            </div>
                        }
                        else if (!parts.Any())
                        {
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-inbox display-1"></i>
                                <p class="mt-3">Немає деталей</p>
                                <a href="/scanning/import" class="btn btn-primary">
                                    <i class="bi bi-upload"></i> Імпортувати проект
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                                <table class="table table-hover table-sm mb-0">
                                    <thead class="table-light sticky-top">
                                        <tr>
                                            <th>Назва</th>
                                            <th>Код</th>
                                            <th class="text-center">Прогрес</th>
                                            <th class="text-center" title="Порізка"><i class="bi bi-scissors"></i></th>
                                            <th class="text-center" title="Поклейка"><i class="bi bi-bounding-box"></i></th>
                                            <th class="text-center" title="Свердління"><i class="bi bi-gear"></i></th>
                                            <th class="text-center" title="Сортування"><i class="bi bi-sort-alpha-down"></i></th>
                                            <th class="text-center" title="Пакування"><i class="bi bi-box-seam"></i></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var part in parts)
                                        {
                                            var rowClass = part.IsFullyCompleted ? "table-success" : "";
                                            
                                            <tr class="@rowClass">
                                                <td>
                                                    <span title="@part.QRCode">@TruncateName(part.Name, 20)</span>
                                                </td>
                                                <td><code class="small">@part.Code</code></td>
                                                <td class="text-center">
                                                    <div class="progress" style="height: 14px; min-width: 50px;">
                                                        <div class="progress-bar @(part.IsFullyCompleted ? "bg-success" : "bg-primary")" 
                                                             style="width: @(part.ProgressPercent)%">
                                                            <small>@(part.ProgressPercent)%</small>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="text-center">@GetStageIcon(part, ProductionStage.Cutting)</td>
                                                <td class="text-center">@GetEdgeBandingStatus(part)</td>
                                                <td class="text-center">@GetStageIcon(part, ProductionStage.Drilling)</td>
                                                <td class="text-center">@GetStageIcon(part, ProductionStage.Sorting)</td>
                                                <td class="text-center">@GetStageIcon(part, ProductionStage.Packing)</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <!-- Пагінація -->
                            @if (totalPages > 1)
                            {
                                <div class="card-footer d-flex justify-content-between align-items-center py-2">
                                    <small class="text-muted">@currentPage / @totalPages</small>
                                    <nav>
                                        <ul class="pagination pagination-sm mb-0">
                                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                                <button class="page-link" @onclick="() => GoToPage(currentPage - 1)">
                                                    <i class="bi bi-chevron-left"></i>
                                                </button>
                                            </li>
                                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                                <button class="page-link" @onclick="() => GoToPage(currentPage + 1)">
                                                    <i class="bi bi-chevron-right"></i>
                                                </button>
                                            </li>
                                        </ul>
                                    </nav>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Модальне вікно реєстрації браку -->
@if (showDefectModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Реєстрація браку</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseDefectModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(defectError))
                    {
                        <div class="alert alert-danger py-2">@defectError</div>
                    }

                    <div class="mb-3">
                        <label class="form-label">QR-код деталі</label>
                        <input type="text" class="form-control" value="@qrCode" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Тип дефекту <span class="text-danger">*</span></label>
                        <select class="form-select" @bind="defectType">
                            <option value="">-- Оберіть тип --</option>
                            @foreach (var type in DefectService.DefectTypes)
                            {
                                <option value="@type">@type</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Тяжкість</label>
                        <div class="d-flex align-items-center gap-2">
                            <input type="range" class="form-range" min="1" max="5" @bind="defectSeverity" />
                            <span class="badge bg-danger">@defectSeverity / 5</span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="defectRepairable" @bind="defectIsRepairable" />
                            <label class="form-check-label" for="defectRepairable">
                                Підлягає виправленню
                            </label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Опис (необов'язково)</label>
                        <textarea class="form-control" rows="2" @bind="defectDescription" placeholder="Опишіть дефект..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseDefectModal">Скасувати</button>
                    <button type="button" class="btn btn-danger" @onclick="SaveDefect" disabled="@isSavingDefect">
                        @if (isSavingDefect)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-exclamation-triangle me-1"></i> Зареєструвати брак
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int WorkstationId { get; set; }

    [SupplyParameterFromQuery]
    public string? Project { get; set; }

    // Компонент авторизації
    private WorkerLogin? workerLoginRef;
    private WorkerScanContext? workerContext;

    // Станції
    private List<WorkstationEntity> workstations = new();
    private int selectedWorkstationId;
    private WorkstationEntity? currentWorkstation;
    private bool useStationStage = true;

    // Сканування
    private ElementReference qrInput;
    private string qrCode = "";
    private ProductionStage? selectedStage;
    private bool isScanning = false;
    private bool isLoading = true;

    private Part? lastScannedPart;
    private string? scanMessage;
    private string scanMessageClass = "info";
    private string scanMessageIcon = "info-circle";

    // Проекти та статистика
    private List<Tablitsya3.Data.Entities.ImportedProjectEntity> projects = new();
    private string selectedProjectUuid = "";
    private ProjectStatistics? projectStatistics;

    // Таблиця
    private List<Part> parts = new();
    private List<string> fileNames = new();
    private int currentPage = 1;
    private int pageSize = 30;
    private int totalParts = 0;
    private int totalPages => (int)Math.Ceiling((double)totalParts / pageSize);

    // Фільтри
    private string filterFileName = "";
    private string filterCompleted = "";

    // Чи можна сканувати
    private bool CanScan => selectedWorkstationId > 0 && 
                            (workerContext != null || currentWorkstation?.RequiresWorkerAuth != true);

    protected override async Task OnInitializedAsync()
    {
        // Завантажуємо список станцій
        workstations = await WorkstationService.GetAllWorkstationsAsync();
        
        // Якщо є WorkstationId в URL - використовуємо
        if (WorkstationId > 0)
        {
            selectedWorkstationId = WorkstationId;
            await OnWorkstationSelected();
        }
        
        // Якщо є параметр Project з URL
        if (!string.IsNullOrEmpty(Project))
        {
            selectedProjectUuid = Project;
        }
        
        await LoadAllData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && CanScan)
        {
            await FocusQRInput();
        }
    }

    private async Task OnWorkstationSelected()
    {
        currentWorkstation = workstations.FirstOrDefault(w => w.Id == selectedWorkstationId);
        
        if (currentWorkstation != null)
        {
            // Автоматично встановлюємо етап станції
            useStationStage = true;
            selectedStage = currentWorkstation.Stage;
        }
        
        StateHasChanged();
    }

    private async Task OnWorkerAuthenticated(WorkerScanContext context)
    {
        workerContext = context;
        Logger.LogInfo($"Працівник {context.WorkerName} авторизувався на станції {context.WorkstationName}", "ScanningDashboard");
        
        await FocusQRInput();
        StateHasChanged();
    }

    private async Task OnWorkerLoggedOut()
    {
        workerContext = null;
        Logger.LogInfo("Працівник вийшов зі станції", "ScanningDashboard");
        StateHasChanged();
    }

    private async Task LoadAllData()
    {
        await LoadProjects();
        await LoadFileNames();
        await LoadStatistics();
        await LoadData();
    }

    private async Task OnProjectChanged()
    {
        currentPage = 1;
        filterFileName = "";
        await LoadStatistics();
        await LoadData();
    }

    private async Task LoadStatistics()
    {
        try
        {
            if (string.IsNullOrEmpty(selectedProjectUuid))
            {
                projectStatistics = await ScanningService.GetOverallStatisticsAsync();
            }
            else
            {
                projectStatistics = await ScanningService.GetProjectStatisticsAsync(selectedProjectUuid);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError($"Помилка завантаження статистики: {ex.Message}", ex, "ScanningDashboard");
        }
    }

    private async Task LoadProjects()
    {
        try
        {
            projects = await ScanningService.GetProjectsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError($"Помилка завантаження проектів: {ex.Message}", ex, "ScanningDashboard");
        }
    }

    private string GetSelectedProjectName()
    {
        var project = projects.FirstOrDefault(p => p.ProjectUuid == selectedProjectUuid);
        return project?.FileName ?? selectedProjectUuid;
    }

    private async Task FocusQRInput()
    {
        try
        {
            await Task.Delay(100);
            await JSRuntime.InvokeVoidAsync("eval", "document.querySelector('input[placeholder*=\"QR\"]')?.focus()");
        }
        catch { }
    }

    private async Task LoadData()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            bool? completed = string.IsNullOrEmpty(filterCompleted) ? null : bool.Parse(filterCompleted);
            
            var projectFilter = !string.IsNullOrEmpty(selectedProjectUuid) ? selectedProjectUuid : Project;
            
            var (loadedParts, total) = await ScanningService.GetPartsAsync(
                currentPage, 
                pageSize, 
                projectFilter,
                string.IsNullOrEmpty(filterFileName) ? null : filterFileName,
                null,
                completed);

            parts = loadedParts;
            totalParts = total;
        }
        catch (Exception ex)
        {
            Logger.LogError($"Помилка завантаження: {ex.Message}", ex, "ScanningDashboard");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadFileNames()
    {
        try
        {
            fileNames = await ScanningService.GetUniqueFileNamesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError($"Помилка завантаження файлів: {ex.Message}", ex, "ScanningDashboard");
        }
    }

    private async Task GoToPage(int page)
    {
        if (page < 1 || page > totalPages) return;
        currentPage = page;
        await LoadData();
    }

    private async Task OnQRKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrEmpty(qrCode))
        {
            await ProcessScan();
        }
    }

    private async Task ProcessScan()
    {
        if (string.IsNullOrEmpty(qrCode) || !CanScan) return;

        isScanning = true;
        ClearScanMessage();
        StateHasChanged();

        try
        {
            // Визначаємо етап
            ProductionStage? stage = useStationStage && currentWorkstation != null 
                ? currentWorkstation.Stage 
                : selectedStage;
            
            // Сканування з інформацією про працівника
            var result = await ScanningService.ScanQRCodeAsync(
                qrCode, 
                stage,
                workerContext?.WorkerId,
                workerContext?.WorkstationId,
                workerContext?.SessionId);

            if (result.Success)
            {
                lastScannedPart = result.Part;
                ShowScanMessage(result.Message, "success", result.IsFullyCompleted ? "trophy" : "check-circle");
                
                // Оновлюємо активність сесії
                if (workerLoginRef != null)
                {
                    await workerLoginRef.UpdateActivityAsync();
                }
                
                // Оновлюємо статистику та таблицю
                await LoadStatistics();
                await LoadData();
            }
            else
            {
                ShowScanMessage(result.Message, "danger", "x-circle");
                
                if (result.Part != null)
                {
                    lastScannedPart = result.Part;
                }
            }

            // Очищаємо поле
            qrCode = "";
            await FocusQRInput();
        }
        catch (Exception ex)
        {
            Logger.LogError($"Помилка сканування: {ex.Message}", ex, "ScanningDashboard");
            ShowScanMessage($"Помилка: {ex.Message}", "danger", "x-circle");
        }
        finally
        {
            isScanning = false;
        }
    }

    private void ClearQR()
    {
        qrCode = "";
        _ = FocusQRInput();
    }

    private void ShowScanMessage(string message, string cssClass, string icon)
    {
        scanMessage = message;
        scanMessageClass = cssClass;
        scanMessageIcon = icon;
    }

    private void ClearScanMessage()
    {
        scanMessage = null;
    }

    private MarkupString GetStageIcon(Part part, ProductionStage stage)
    {
        if (!part.IsStageRequired(stage))
        {
            return new MarkupString("<span class='text-muted'>—</span>");
        }

        if (part.IsStageCompleted(stage))
        {
            return new MarkupString("<i class='bi bi-check-circle-fill text-success'></i>");
        }

        if (part.CurrentStage == stage)
        {
            return new MarkupString("<i class='bi bi-circle-fill text-warning'></i>");
        }

        return new MarkupString("<i class='bi bi-circle text-muted'></i>");
    }

    private MarkupString GetEdgeBandingStatus(Part part)
    {
        if (!part.RequiresEdgeBanding)
        {
            return new MarkupString("<span class='text-muted'>—</span>");
        }

        if (part.EdgeBandingSidesRequired > 0)
        {
            var color = part.IsEdgeBandingFullyCompleted() ? "text-success" : "text-warning";
            return new MarkupString($"<span class='{color}'>{part.EdgeBandingSidesCompleted}/{part.EdgeBandingSidesRequired}</span>");
        }

        return GetStageIcon(part, ProductionStage.EdgeBanding);
    }

    private string TruncateName(string name, int maxLength)
    {
        if (string.IsNullOrEmpty(name)) return "";
        return name.Length > maxLength ? name.Substring(0, maxLength) + "..." : name;
    }

    #region Defect Modal

    private bool showDefectModal = false;
    private string defectType = "";
    private string defectDescription = "";
    private int defectSeverity = 3;
    private bool defectIsRepairable = true;
    private string? defectError;
    private bool isSavingDefect = false;

    private void ShowDefectModal()
    {
        defectType = "";
        defectDescription = "";
        defectSeverity = 3;
        defectIsRepairable = true;
        defectError = null;
        showDefectModal = true;
    }

    private void CloseDefectModal()
    {
        showDefectModal = false;
        defectError = null;
    }

    private async Task SaveDefect()
    {
        if (string.IsNullOrEmpty(qrCode))
        {
            defectError = "Введіть QR-код деталі";
            return;
        }

        if (string.IsNullOrEmpty(defectType))
        {
            defectError = "Оберіть тип дефекту";
            return;
        }

        isSavingDefect = true;
        defectError = null;
        StateHasChanged();

        try
        {
            var stage = useStationStage && currentWorkstation != null 
                ? (int)currentWorkstation.Stage 
                : (int)(selectedStage ?? ProductionStage.Cutting);

            var result = await DefectService.CreateDefectFromQRAsync(
                qrCode,
                defectType,
                stage,
                workerContext?.WorkerId,
                workerContext?.WorkstationId,
                defectDescription,
                defectSeverity,
                defectIsRepairable);

            if (result != null)
            {
                ShowScanMessage($"🚨 Брак зареєстровано: {defectType}", "warning", "exclamation-triangle");
                CloseDefectModal();
                qrCode = "";
                await FocusQRInput();
            }
            else
            {
                defectError = "Деталь з таким QR-кодом не знайдена";
            }
        }
        catch (Exception ex)
        {
            defectError = $"Помилка: {ex.Message}";
            Logger.LogError($"Помилка збереження дефекту: {ex.Message}", ex, "ScanningDashboard");
        }
        finally
        {
            isSavingDefect = false;
        }
    }

    #endregion
}
