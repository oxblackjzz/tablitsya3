@page "/"
@attribute [Authorize(Policy = AuthPolicies.AnyAuthenticated)]
@using Tablitsya3.Models
@using Tablitsya3.Services
@inject UnifiedStorageService StorageService
@inject WorkshopConfigService WorkshopConfigService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Головна - Планування виробництва</PageTitle>

<!-- Hero Section -->
<div class="mb-4">
    <h1 class="mb-2">
        <i class="bi bi-speedometer2 text-primary"></i> Панель керування
    </h1>
    <p class="text-secondary fs-5">Система планування виробництва меблів</p>
</div>

<!-- KPI Stats -->
<div class="row g-4 mb-4">
    <div class="col-md-6 col-lg-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="mb-1 opacity-75">Всього замовлень</p>
                    <h3>@totalOrders</h3>
                </div>
                <i class="bi bi-clipboard-data fs-1 opacity-50"></i>
            </div>
        </div>
    </div>
    
    <div class="col-md-6 col-lg-3">
        <div class="stat-card success">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="mb-1 opacity-75">Активних цехів</p>
                    <h3>@workshops.Count</h3>
                </div>
                <i class="bi bi-building fs-1 opacity-50"></i>
            </div>
        </div>
    </div>
    
    <div class="col-md-6 col-lg-3">
        <div class="stat-card warning">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="mb-1 opacity-75">Обсяг в роботі</p>
                    <h3>@totalSquareMeters.ToString("N0") м²</h3>
                </div>
                <i class="bi bi-rulers fs-1 opacity-50"></i>
            </div>
        </div>
    </div>
    
    <div class="col-md-6 col-lg-3">
        <div class="stat-card info">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="mb-1 opacity-75">Тип сховища</p>
                    <h3 class="fs-4">@storageType</h3>
                </div>
                <i class="bi bi-database fs-1 opacity-50"></i>
            </div>
        </div>
    </div>
</div>

<!-- Workshop Stats -->
@if (workshopStats.Any())
{
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="bi bi-bar-chart-fill me-2"></i>Завантаженість цехів
            </h5>
        </div>
        <div class="card-body">
            <div class="row g-4">
                @foreach (var stat in workshopStats)
                {
                    var loadPercentage = stat.Capacity > 0 
                        ? Math.Min(100, (stat.TotalSquareMeters / stat.Capacity) * 100 / 30) 
                        : 0;
                    var progressColor = loadPercentage > 80 ? "danger" : loadPercentage > 50 ? "warning" : "success";
                    
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h6 class="mb-0">
                                        <span class="badge bg-@stat.ColorClass me-2">@stat.WorkshopNumber</span>
                                        @stat.Name
                                    </h6>
                                    <span class="badge bg-light text-dark">@stat.OrderCount замов.</span>
                                </div>
                                
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between mb-1">
                                        <small class="text-secondary">Завантаження (30 днів)</small>
                                        <small class="fw-semibold">@loadPercentage.ToString("F0")%</small>
                                    </div>
                                    <div class="progress" style="height: 8px;">
                                        <div class="progress-bar bg-@progressColor" 
                                             role="progressbar" 
                                             style="width: @loadPercentage.ToString("F0")%">
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row text-center">
                                    <div class="col-6">
                                        <div class="text-secondary small">Обсяг</div>
                                        <div class="fw-bold">@stat.TotalSquareMeters.ToString("N0") м²</div>
                                    </div>
                                    <div class="col-6">
                                        <div class="text-secondary small">Потужність</div>
                                        <div class="fw-bold">@stat.Capacity м²/день</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- Quick Actions -->
<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">
            <i class="bi bi-lightning-charge-fill me-2"></i>Швидкі дії
        </h5>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-6 col-lg-3">
                <a href="/bulk-order-entry" class="btn btn-success w-100 py-3">
                    <i class="bi bi-plus-circle-fill d-block fs-3 mb-2"></i>
                    <span>Нове замовлення</span>
                </a>
            </div>
            <div class="col-6 col-lg-3">
                <a href="/production-planning" class="btn btn-primary w-100 py-3">
                    <i class="bi bi-calendar-check-fill d-block fs-3 mb-2"></i>
                    <span>Планування</span>
                </a>
            </div>
            <div class="col-6 col-lg-3">
                <a href="/workshop-settings" class="btn btn-outline-secondary w-100 py-3">
                    <i class="bi bi-sliders d-block fs-3 mb-2"></i>
                    <span>Налаштування</span>
                </a>
            </div>
            <div class="col-6 col-lg-3">
                <a href="/backup-management" class="btn btn-outline-info w-100 py-3">
                    <i class="bi bi-cloud-arrow-up-fill d-block fs-3 mb-2"></i>
                    <span>Бекапи</span>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Recent Activity -->
@if (workshopData != null && workshopData.LastUpdated > DateTime.MinValue)
{
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="bi bi-clock-history me-2"></i>Інформація
            </h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <div class="text-secondary small">Останнє оновлення</div>
                    <div class="fw-semibold">@workshopData.LastUpdated.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
                </div>
                <div class="col-md-4">
                    <div class="text-secondary small">Початок планування</div>
                    <div class="fw-semibold">@workshopData.StartDate.ToString("dd.MM.yyyy")</div>
                </div>
                <div class="col-md-4">
                    <div class="text-secondary small">Кастомних дат</div>
                    <div class="fw-semibold">@workshopData.CustomCompletionDates.Count</div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private WorkshopData? workshopData;
    private List<WorkshopConfig> workshops = new();
    private List<WorkshopStatistic> workshopStats = new();
    
    private int totalOrders = 0;
    private double totalSquareMeters = 0;
    private string storageType = "|...|";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            workshops = await WorkshopConfigService.GetActiveWorkshopsAsync();
            workshopData = await StorageService.LoadWorkshopDataAsync();
            storageType = StorageService.GetStorageType();

            if (workshopData != null)
            {
                totalOrders = workshopData.WorkshopOrders.Sum(x => x.Value.Count);
                totalSquareMeters = workshopData.WorkshopOrders.Sum(x => x.Value.Sum());

                workshopStats = workshops.Select(w => new WorkshopStatistic
                {
                    WorkshopNumber = w.Number,
                    Name = w.Name,
                    ColorClass = w.ColorClass,
                    OrderCount = workshopData.WorkshopOrders.GetValueOrDefault(w.Number)?.Count ?? 0,
                    TotalSquareMeters = workshopData.WorkshopOrders.GetValueOrDefault(w.Number)?.Sum() ?? 0,
                    Capacity = workshopData.GetCapacity(w.Number)
                }).Where(s => s.OrderCount > 0 || s.Capacity > 0).ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
    }

    private class WorkshopStatistic
    {
        public int WorkshopNumber { get; set; }
        public string Name { get; set; } = "";
        public string ColorClass { get; set; } = "secondary";
        public int OrderCount { get; set; }
        public double TotalSquareMeters { get; set; }
        public int Capacity { get; set; }
    }
}
