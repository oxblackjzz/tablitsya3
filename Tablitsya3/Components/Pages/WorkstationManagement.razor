@page "/workstations"
@attribute [Authorize(Policy = AuthPolicies.ManagerOrAbove)]
@using Tablitsya3.Data.Entities
@using Tablitsya3.Models.Scanning
@using Tablitsya3.Services
@inject WorkstationService WorkstationService
@inject WorkerAuthService WorkerAuthService
@inject WorkshopConfigService WorkshopConfigService
@inject WorkstationScannerService ScannerService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Управління станціями</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-pc-display-horizontal me-2"></i>Управління станціями</h2>
        <div class="btn-group">
            <button class="btn btn-primary" @onclick="ShowAddStationModal">
                <i class="bi bi-plus-lg me-1"></i>Додати станцію
            </button>
            <button class="btn btn-outline-primary" @onclick="ShowCreateDefaultModal">
                <i class="bi bi-magic me-1"></i>Створити типові
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Завантаження...</span>
            </div>
        </div>
    }
    else
    {
        <!-- Фільтри -->
        <div class="card mb-4">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Цех</label>
                        <select class="form-select" @bind="selectedWorkshop" @bind:after="LoadStations">
                            <option value="0">Всі цехи</option>
                            @foreach (var workshopNum in workshopNumbers)
                            {
                                <option value="@workshopNum">Цех @workshopNum</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Етап</label>
                        <select class="form-select" @bind="selectedStage" @bind:after="LoadStations">
                            <option value="-1">Всі етапи</option>
                            @foreach (ProductionStage stage in Enum.GetValues<ProductionStage>())
                            {
                                <option value="@((int)stage)">@stage.GetDisplayName()</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Статус</label>
                        <select class="form-select" @bind="showInactive" @bind:after="LoadStations">
                            <option value="false">Тільки активні</option>
                            <option value="true">Всі</option>
                        </select>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button class="btn btn-outline-secondary w-100" @onclick="LoadStations">
                            <i class="bi bi-arrow-clockwise me-1"></i>Оновити
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Активні сесії -->
        @if (activeSessions.Any())
        {
            <div class="card mb-4 border-success">
                <div class="card-header bg-success text-white">
                    <i class="bi bi-person-check me-2"></i>Активні сесії (@activeSessions.Count)
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Станція</th>
                                    <th>Працівник</th>
                                    <th>Початок</th>
                                    <th>Сканувань</th>
                                    <th>Дії</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var (ws, session, worker) in activeSessions)
                                {
                                    <tr>
                                        <td>
                                            <strong>@ws.Name</strong>
                                            <br /><small class="text-muted">@ws.StageName</small>
                                        </td>
                                        <td>@worker.DisplayName</td>
                                        <td>@session.StartTime.ToLocalTime().ToString("HH:mm")</td>
                                        <td>
                                            <span class="badge bg-info">@session.ScansCount</span>
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-danger" 
                                                    @onclick="() => EndSession(session.SessionToken)">
                                                <i class="bi bi-box-arrow-right"></i> Завершити
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- Станції по етапах -->
        @foreach (ProductionStage stage in Enum.GetValues<ProductionStage>())
        {
            var stageStations = filteredStations.Where(s => s.ProductionStage == (int)stage).ToList();
            if (selectedStage >= 0 && selectedStage != (int)stage) continue;
            if (!stageStations.Any() && selectedStage < 0) continue;

            <div class="card mb-4">
                <div class="card-header d-flex align-items-center" style="background-color: @(stage.GetColor())20; border-left: 4px solid @stage.GetColor()">
                    <i class="@stage.GetIcon() me-2" style="color: @stage.GetColor()"></i>
                    <strong>@stage.GetDisplayName()</strong>
                    <span class="badge bg-secondary ms-2">@stageStations.Count станцій</span>
                </div>
                <div class="card-body p-0">
                    @if (!stageStations.Any())
                    {
                        <div class="text-center py-4 text-muted">
                            Станцій не знайдено
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Код</th>
                                        <th>Назва</th>
                                        <th>Цех</th>
                                        <th>Локація</th>
                                        <th>Авторизація</th>
                                        <th>Тайм-аут</th>
                                        <th>Статус</th>
                                        <th>Дії</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var station in stageStations)
                                    {
                                        var hasActiveSession = activeSessions.Any(s => s.Workstation.Id == station.Id);
                                        <tr class="@(station.IsActive ? "" : "table-secondary")">
                                            <td><code>@station.StationCode</code></td>
                                            <td>
                                                <strong>@station.Name</strong>
                                                @if (!string.IsNullOrEmpty(station.Description))
                                                {
                                                    <br /><small class="text-muted">@station.Description</small>
                                                }
                                            </td>
                                            <td><span class="badge bg-info">Цех @station.WorkshopNumber</span></td>
                                            <td>@(station.Location ?? "-")</td>
                                            <td>
                                                @if (station.RequiresWorkerAuth)
                                                {
                                                    <span class="badge bg-warning text-dark">
                                                        <i class="bi bi-lock"></i> Потрібна
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">
                                                        <i class="bi bi-unlock"></i> Ні
                                                    </span>
                                                }
                                            </td>
                                            <td>
                                                @if (station.SessionTimeoutMinutes > 0)
                                                {
                                                    <span>@station.SessionTimeoutMinutes хв</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Без обмежень</span>
                                                }
                                            </td>
                                            <td>
                                                @if (hasActiveSession)
                                                {
                                                    <span class="badge bg-success">
                                                        <i class="bi bi-person-check"></i> Активна
                                                    </span>
                                                }
                                                else if (station.IsActive)
                                                {
                                                    <span class="badge bg-secondary">Вільна</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-dark">Неактивна</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <button class="btn btn-outline-primary" 
                                                            @onclick="() => ShowEditStationModal(station)" title="Редагувати">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    <button class="btn btn-outline-info"
                                                            @onclick="() => ShowScannersModal(station)" title="Сканери">
                                                        <i class="bi bi-upc-scan"></i>
                                                    </button>
                                                    @if (station.IsActive)
                                                    {
                                                        <button class="btn btn-outline-warning" 
                                                                @onclick="() => DeactivateStation(station)" title="Деактивувати">
                                                            <i class="bi bi-pause-circle"></i>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-outline-success" 
                                                                @onclick="() => ActivateStation(station)" title="Активувати">
                                                            <i class="bi bi-play-circle"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

<!-- Модальне вікно додавання/редагування станції -->
@if (showStationModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(editingStation.Id == 0 ? "Додати станцію" : "Редагувати станцію")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseStationModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Код станції</label>
                            <input type="text" class="form-control" @bind="editingStation.StationCode" 
                                   placeholder="Автогенерація" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Цех *</label>
                            <select class="form-select" @bind="editingStation.WorkshopNumber">
                                @foreach (var workshopNum in workshopNumbers)
                                {
                                    <option value="@workshopNum">Цех @workshopNum</option>
                                }
                            </select>
                        </div>
                        
                        <div class="col-12">
                            <label class="form-label">Назва *</label>
                            <input type="text" class="form-control" @bind="editingStation.Name" 
                                   placeholder="Порізочний станок #1" />
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label">Етап виробництва *</label>
                            <select class="form-select" @bind="editingStation.ProductionStage">
                                @foreach (ProductionStage stage in Enum.GetValues<ProductionStage>())
                                {
                                    <option value="@((int)stage)">@stage.GetDisplayName()</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Потужність (м³/день)</label>
                            <input type="number" class="form-control" @bind="editingStation.Capacity" 
                                   min="0" step="1" />
                            <small class="text-muted">Залиште 0 якщо не потрібно враховувати</small>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label">Локація</label>
                            <input type="text" class="form-control" @bind="editingStation.Location" 
                                   placeholder="Зона A, Ряд 1" />
                        </div>
                        
                        <div class="col-12">
                            <label class="form-label">Опис</label>
                            <textarea class="form-control" rows="2" @bind="editingStation.Description"></textarea>
                        </div>
                        
                        <div class="col-md-6">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="requiresAuth" 
                                       @bind="editingStation.RequiresWorkerAuth" />
                                <label class="form-check-label" for="requiresAuth">
                                    Потрібна авторизація працівника
                                </label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Тайм-аут сесії (хв)</label>
                            <input type="number" class="form-control" @bind="editingStation.SessionTimeoutMinutes" 
                                   min="0" max="480" />
                            <small class="text-muted">0 = без обмежень</small>
                        </div>
                        
                        <div class="col-12">
                            <label class="form-label">Ідентифікатор пристрою</label>
                            <input type="text" class="form-control" @bind="editingStation.DeviceIdentifier" 
                                   placeholder="IP-адреса або унікальний ID" />
                        </div>

                        <div class="col-12">
                            <hr class="my-2" />
                            <div class="alert alert-info py-2 mb-0">
                                <i class="bi bi-info-circle me-1"></i>
                                Сканери підключаються через окрему кнопку <strong>«Сканери»</strong> у списку станцій.
                                Можна додати декілька сканерів на одну станцію (промисловий + ручні).
                            </div>
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseStationModal">Скасувати</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveStation" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Зберегти
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Модальне вікно створення типових станцій -->
@if (showCreateDefaultModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Створити типові станції</h5>
                    <button type="button" class="btn-close" @onclick="() => showCreateDefaultModal = false"></button>
                </div>
                <div class="modal-body">
                    <p>Буде створено по одній станції для кожного етапу виробництва.</p>
                    <div class="mb-3">
                        <label class="form-label">Виберіть цех</label>
                        <select class="form-select" @bind="createDefaultWorkshop">
                            @foreach (var workshopNum in workshopNumbers)
                            {
                                <option value="@workshopNum">Цех @workshopNum</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showCreateDefaultModal = false">Скасувати</button>
                    <button type="button" class="btn btn-primary" @onclick="CreateDefaultStations">
                        Створити
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Модальне вікно керування сканерами станції -->
@if (showScannersModal && scannersStation != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-upc-scan me-2"></i>Сканери станції: <strong>@scannersStation.Name</strong>
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseScannersModal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info py-2">
                        <i class="bi bi-info-circle me-1"></i>
                        Можна додати декілька сканерів: один промисловий (основний) та додаткові ручні для роботи з браком.
                    </div>

                    @if (stationScanners.Count == 0)
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-inbox display-6 d-block mb-2"></i>
                            Сканерів немає. Додайте перший сканер для цієї станції.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th></th>
                                        <th>Назва</th>
                                        <th>Роль</th>
                                        <th>Модель</th>
                                        <th>Підключення</th>
                                        <th>Статус</th>
                                        <th>Дії</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var sc in stationScanners)
                                    {
                                        <tr>
                                            <td>
                                                @if (sc.IsPrimary)
                                                {
                                                    <span class="badge bg-warning text-dark" title="Основний сканер">
                                                        <i class="bi bi-star-fill"></i>
                                                    </span>
                                                }
                                            </td>
                                            <td><strong>@sc.Name</strong></td>
                                            <td>@(((WorkstationScannerRole)sc.Role).GetDisplayName())</td>
                                            <td>@(((ScannerModel)sc.ScannerModel).GetDisplayName())</td>
                                            <td>@(((ScannerConnectionType)sc.ConnectionType).GetDisplayName())</td>
                                            <td>
                                                @if (sc.IsEnabled)
                                                {
                                                    <span class="badge bg-success">Увімкнено</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Вимкнено</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    @if (!sc.IsPrimary)
                                                    {
                                                        <button class="btn btn-outline-warning" title="Зробити основним"
                                                                @onclick="() => MakePrimaryScanner(sc.Id)">
                                                            <i class="bi bi-star"></i>
                                                        </button>
                                                    }
                                                    <button class="btn btn-outline-primary" title="Редагувати"
                                                            @onclick="() => ShowScannerEditor(sc)">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    <button class="btn btn-outline-danger" title="Видалити"
                                                            @onclick="() => DeleteScanner(sc.Id)">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    @if (editingScanner != null)
                    {
                        <hr />
                        <h6 class="mb-3">
                            @(editingScanner.Id == 0 ? "Додати сканер" : $"Редагувати: {editingScanner.Name}")
                        </h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Назва пристрою *</label>
                                <input type="text" class="form-control" @bind="editingScanner.Name"
                                       placeholder="Напр. FS-40 на робочому місці" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Роль</label>
                                <select class="form-select" @bind="editingScanner.Role">
                                    @foreach (WorkstationScannerRole r in Enum.GetValues<WorkstationScannerRole>())
                                    {
                                        <option value="@((int)r)">@r.GetDisplayName()</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">&nbsp;</label>
                                <div class="form-check form-switch mt-2">
                                    <input class="form-check-input" type="checkbox" id="scIsEnabled"
                                           @bind="editingScanner.IsEnabled" />
                                    <label class="form-check-label" for="scIsEnabled">Увімкнено</label>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Модель</label>
                                <select class="form-select" @bind="editingScanner.ScannerModel">
                                    @foreach (ScannerModel m in Enum.GetValues<ScannerModel>())
                                    {
                                        <option value="@((int)m)">@m.GetDisplayName()</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Тип підключення</label>
                                <select class="form-select" @bind="editingScanner.ConnectionType">
                                    @foreach (ScannerConnectionType c in Enum.GetValues<ScannerConnectionType>())
                                    {
                                        <option value="@((int)c)">@c.GetDisplayName()</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Серійний номер</label>
                                <input type="text" class="form-control" @bind="editingScanner.SerialNumber" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Префікс</label>
                                <input type="text" class="form-control" @bind="editingScanner.Prefix" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Суфікс</label>
                                <input type="text" class="form-control" @bind="editingScanner.Suffix" placeholder="\r\n" />
                            </div>

                            @{
                                var ec = (ScannerConnectionType)editingScanner.ConnectionType;
                            }
                            @if (ec == ScannerConnectionType.UsbHid || ec == ScannerConnectionType.WebHid)
                            {
                                <div class="col-md-6">
                                    <label class="form-label">USB VID (hex)</label>
                                    <input type="text" class="form-control" @bind="editingScanner.UsbVid" placeholder="0x1EAB" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">USB PID (hex)</label>
                                    <input type="text" class="form-control" @bind="editingScanner.UsbPid" placeholder="0x1D06" />
                                </div>
                            }
                            @if (ec == ScannerConnectionType.UsbSerial || ec == ScannerConnectionType.WebSerial)
                            {
                                <div class="col-md-6">
                                    <label class="form-label">COM-порт</label>
                                    <input type="text" class="form-control" @bind="editingScanner.ComPort" placeholder="COM3" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Baud rate</label>
                                    <input type="number" class="form-control" @bind="editingScanner.BaudRate" placeholder="9600" />
                                </div>
                            }
                            @if (ec == ScannerConnectionType.BluetoothHid || ec == ScannerConnectionType.BluetoothSpp)
                            {
                                <div class="col-12">
                                    <label class="form-label">MAC-адреса</label>
                                    <input type="text" class="form-control" @bind="editingScanner.BluetoothMac" placeholder="AA:BB:CC:DD:EE:FF" />
                                </div>
                            }
                            @if (ec == ScannerConnectionType.WifiTcp)
                            {
                                <div class="col-md-8">
                                    <label class="form-label">IP-адреса</label>
                                    <input type="text" class="form-control" @bind="editingScanner.IpAddress" placeholder="192.168.1.50" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">TCP-порт</label>
                                    <input type="number" class="form-control" @bind="editingScanner.TcpPort" />
                                </div>
                            }
                            @if (ec == ScannerConnectionType.NetworkHttp)
                            {
                                <div class="col-12">
                                    <label class="form-label">Webhook URL</label>
                                    <input type="text" class="form-control" @bind="editingScanner.WebhookUrl" />
                                </div>
                            }

                            <div class="col-12">
                                <label class="form-label">Додаткові параметри (JSON, опц.)</label>
                                <textarea class="form-control" rows="2" @bind="editingScanner.ExtraJson"
                                          placeholder='{"timeout":1000}'></textarea>
                            </div>

                            <div class="col-12 d-flex gap-2 justify-content-end">
                                <button class="btn btn-secondary" @onclick="CancelScannerEdit">Скасувати</button>
                                <button class="btn btn-primary" @onclick="SaveScanner" disabled="@isSavingScanner">
                                    @if (isSavingScanner) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    <i class="bi bi-save me-1"></i>Зберегти
                                </button>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    @if (editingScanner == null)
                    {
                        <button class="btn btn-success" @onclick="AddNewScanner">
                            <i class="bi bi-plus-lg me-1"></i>Додати сканер
                        </button>
                    }
                    <button class="btn btn-secondary" @onclick="CloseScannersModal">Закрити</button>
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(alertMessage))
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
        <div class="toast show @(alertType == "success" ? "bg-success" : alertType == "error" ? "bg-danger" : "bg-info") text-white">
            <div class="toast-body d-flex justify-content-between align-items-center">
                @alertMessage
                <button type="button" class="btn-close btn-close-white ms-2" @onclick="() => alertMessage = string.Empty"></button>
            </div>
        </div>
    </div>
}

@code {
    private List<WorkstationEntity> stations = new();
    private List<(WorkstationEntity Workstation, WorkerSessionEntity Session, WorkerEntity Worker)> activeSessions = new();
    private List<int> workshopNumbers = new();
    
    private bool isLoading = true;
    private bool isSaving = false;
    
    private int selectedWorkshop = 0;
    private int selectedStage = -1;
    private bool showInactive = false;
    
    private bool showStationModal = false;
    private WorkstationEntity editingStation = new();
    
    private bool showCreateDefaultModal = false;
    private int createDefaultWorkshop = 1;
    
    private string alertMessage = string.Empty;
    private string alertType = "info";

    private IEnumerable<WorkstationEntity> filteredStations => stations
        .Where(s => selectedWorkshop == 0 || s.WorkshopNumber == selectedWorkshop)
        .Where(s => selectedStage < 0 || s.ProductionStage == selectedStage)
        .OrderBy(s => s.WorkshopNumber)
        .ThenBy(s => s.ProductionStage)
        .ThenBy(s => s.Name);

    protected override async Task OnInitializedAsync()
    {
        await LoadWorkshopNumbers();
        await LoadStations();
    }

    private async Task LoadWorkshopNumbers()
    {
        try
        {
            var workshops = await WorkshopConfigService.GetAllWorkshopsAsync();
            workshopNumbers = workshops.Select(w => w.Number).OrderBy(n => n).ToList();
            
            // Якщо немає налаштованих цехів, використовуємо за замовчуванням
            if (!workshopNumbers.Any())
            {
                workshopNumbers = new List<int> { 1, 3, 6, 9 };
            }
            
            // Встановлюємо перший цех як значення за замовчуванням для створення
            if (workshopNumbers.Any())
            {
                createDefaultWorkshop = workshopNumbers.First();
            }
        }
        catch
        {
            workshopNumbers = new List<int> { 1, 3, 6, 9 };
        }
    }

    private async Task LoadStations()
    {
        isLoading = true;
        StateHasChanged();
        
        try
        {
            stations = await WorkstationService.GetAllWorkstationsAsync(showInactive);
            activeSessions = await WorkerAuthService.GetAllActiveSessionsAsync();
        }
        catch (Exception ex)
        {
            ShowAlert($"Помилка завантаження: {ex.Message}", "error");
        }
        
        isLoading = false;
    }

    private void ShowAddStationModal()
    {
        editingStation = new WorkstationEntity 
        { 
            WorkshopNumber = workshopNumbers.FirstOrDefault(1), 
            ProductionStage = (int)ProductionStage.Cutting,
            RequiresWorkerAuth = true,
            SessionTimeoutMinutes = 60,
            IsActive = true 
        };
        showStationModal = true;
    }

    private void ShowEditStationModal(WorkstationEntity station)
    {
        editingStation = new WorkstationEntity
        {
            Id = station.Id,
            StationCode = station.StationCode,
            Name = station.Name,
            Description = station.Description,
            WorkshopNumber = station.WorkshopNumber,
            ProductionStage = station.ProductionStage,
            Location = station.Location,
            IsActive = station.IsActive,
            RequiresWorkerAuth = station.RequiresWorkerAuth,
            SessionTimeoutMinutes = station.SessionTimeoutMinutes,
            DeviceIdentifier = station.DeviceIdentifier,
            Capacity = station.Capacity,
            ScannerModel = station.ScannerModel,
            ScannerConnectionType = station.ScannerConnectionType,
            ScannerEnabled = station.ScannerEnabled,
            ScannerDeviceName = station.ScannerDeviceName,
            ScannerSerialNumber = station.ScannerSerialNumber,
            ScannerUsbVid = station.ScannerUsbVid,
            ScannerUsbPid = station.ScannerUsbPid,
            ScannerComPort = station.ScannerComPort,
            ScannerBaudRate = station.ScannerBaudRate,
            ScannerBluetoothMac = station.ScannerBluetoothMac,
            ScannerIpAddress = station.ScannerIpAddress,
            ScannerTcpPort = station.ScannerTcpPort,
            ScannerWebhookUrl = station.ScannerWebhookUrl,
            ScannerPrefix = station.ScannerPrefix,
            ScannerSuffix = station.ScannerSuffix,
            ScannerExtraJson = station.ScannerExtraJson
        };
        showStationModal = true;
    }

    private void CloseStationModal()
    {
        showStationModal = false;
        editingStation = new();
    }

    private async Task SaveStation()
    {
        if (string.IsNullOrWhiteSpace(editingStation.Name))
        {
            ShowAlert("Введіть назву станції", "error");
            return;
        }

        isSaving = true;
        StateHasChanged();

        try
        {
            if (editingStation.Id == 0)
            {
                await WorkstationService.CreateWorkstationAsync(editingStation);
                ShowAlert("Станцію додано успішно", "success");
            }
            else
            {
                await WorkstationService.UpdateWorkstationAsync(editingStation);
                ShowAlert("Станцію оновлено успішно", "success");
            }

            CloseStationModal();
            await LoadStations();
        }
        catch (Exception ex)
        {
            ShowAlert($"Помилка: {ex.Message}", "error");
        }

        isSaving = false;
    }

    private async Task DeactivateStation(WorkstationEntity station)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", $"Деактивувати станцію {station.Name}?"))
            return;

        try
        {
            await WorkstationService.DeactivateWorkstationAsync(station.Id);
            ShowAlert("Станцію деактивовано", "success");
            await LoadStations();
        }
        catch (Exception ex)
        {
            ShowAlert($"Помилка: {ex.Message}", "error");
        }
    }

    private async Task ActivateStation(WorkstationEntity station)
    {
        try
        {
            station.IsActive = true;
            await WorkstationService.UpdateWorkstationAsync(station);
            ShowAlert("Станцію активовано", "success");
            await LoadStations();
        }
        catch (Exception ex)
        {
            ShowAlert($"Помилка: {ex.Message}", "error");
        }
    }

    private void ShowCreateDefaultModal()
    {
        createDefaultWorkshop = workshopNumbers.FirstOrDefault(1);
        showCreateDefaultModal = true;
    }

    private async Task CreateDefaultStations()
    {
        try
        {
            var created = await WorkstationService.CreateDefaultWorkstationsAsync(createDefaultWorkshop);
            ShowAlert($"Створено {created.Count} станцій для цеху {createDefaultWorkshop}", "success");
            showCreateDefaultModal = false;
            await LoadStations();
        }
        catch (Exception ex)
        {
            ShowAlert($"Помилка: {ex.Message}", "error");
        }
    }

    private async Task EndSession(string sessionToken)
    {
        try
        {
            await WorkerAuthService.LogoutAsync(sessionToken);
            ShowAlert("Сесію завершено", "success");
            await LoadStations();
        }
        catch (Exception ex)
        {
            ShowAlert($"Помилка: {ex.Message}", "error");
        }
    }

    private void ShowAlert(string message, string type)
    {
        alertMessage = message;
        alertType = type;
        StateHasChanged();

        _ = Task.Delay(4000).ContinueWith(_ =>
        {
            alertMessage = string.Empty;
            InvokeAsync(StateHasChanged);
        });
    }

    // === Керування сканерами станції ===
    private bool showScannersModal = false;
    private WorkstationEntity? scannersStation;
    private List<WorkstationScannerEntity> stationScanners = new();
    private WorkstationScannerEntity? editingScanner;
    private bool isSavingScanner = false;

    private async Task ShowScannersModal(WorkstationEntity station)
    {
        scannersStation = station;
        editingScanner = null;
        showScannersModal = true;
        await ReloadScanners();
    }

    private void CloseScannersModal()
    {
        showScannersModal = false;
        scannersStation = null;
        editingScanner = null;
        stationScanners = new();
    }

    private async Task ReloadScanners()
    {
        if (scannersStation == null) return;
        try
        {
            stationScanners = await ScannerService.GetByWorkstationAsync(scannersStation.Id);
        }
        catch (Exception ex)
        {
            ShowAlert($"Помилка завантаження сканерів: {ex.Message}", "error");
        }
    }

    private void AddNewScanner()
    {
        if (scannersStation == null) return;
        editingScanner = new WorkstationScannerEntity
        {
            WorkstationId = scannersStation.Id,
            Name = string.Empty,
            IsEnabled = true,
            Role = (int)WorkstationScannerRole.Industrial
        };
    }

    private void ShowScannerEditor(WorkstationScannerEntity sc)
    {
        editingScanner = new WorkstationScannerEntity
        {
            Id = sc.Id,
            WorkstationId = sc.WorkstationId,
            Name = sc.Name,
            Role = sc.Role,
            IsPrimary = sc.IsPrimary,
            IsEnabled = sc.IsEnabled,
            ScannerModel = sc.ScannerModel,
            ConnectionType = sc.ConnectionType,
            SerialNumber = sc.SerialNumber,
            UsbVid = sc.UsbVid,
            UsbPid = sc.UsbPid,
            ComPort = sc.ComPort,
            BaudRate = sc.BaudRate,
            BluetoothMac = sc.BluetoothMac,
            IpAddress = sc.IpAddress,
            TcpPort = sc.TcpPort,
            WebhookUrl = sc.WebhookUrl,
            Prefix = sc.Prefix,
            Suffix = sc.Suffix,
            ExtraJson = sc.ExtraJson
        };
    }

    private void CancelScannerEdit() => editingScanner = null;

    private async Task SaveScanner()
    {
        if (editingScanner == null) return;
        if (string.IsNullOrWhiteSpace(editingScanner.Name))
        {
            ShowAlert("Вкажіть назву сканера", "error");
            return;
        }
        isSavingScanner = true;
        try
        {
            if (editingScanner.Id == 0)
            {
                await ScannerService.CreateAsync(editingScanner);
                ShowAlert("Сканер додано", "success");
            }
            else
            {
                await ScannerService.UpdateAsync(editingScanner);
                ShowAlert("Сканер оновлено", "success");
            }
            editingScanner = null;
            await ReloadScanners();
        }
        catch (Exception ex)
        {
            ShowAlert($"Помилка: {ex.Message}", "error");
        }
        finally
        {
            isSavingScanner = false;
        }
    }

    private async Task DeleteScanner(int id)
    {
        var ok = await JSRuntime.InvokeAsync<bool>("confirm", "Видалити цей сканер?");
        if (!ok) return;
        try
        {
            await ScannerService.DeleteAsync(id);
            await ReloadScanners();
            ShowAlert("Сканер видалено", "success");
        }
        catch (Exception ex)
        {
            ShowAlert($"Помилка: {ex.Message}", "error");
        }
    }

    private async Task MakePrimaryScanner(int id)
    {
        try
        {
            await ScannerService.SetPrimaryAsync(id);
            await ReloadScanners();
        }
        catch (Exception ex)
        {
            ShowAlert($"Помилка: {ex.Message}", "error");
        }
    }
}
