@inherits LayoutComponentBase
@using Tablitsya3.Models

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
            <AuthorizeView>
                <Authorized>
                    <div class="d-flex align-items-center gap-3">
                        @{
                            var roleClaim = context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                            var role = Enum.TryParse<UserRole>(roleClaim, out var r) ? r : UserRole.Viewer;
                            var displayName = context.User.FindFirst("DisplayName")?.Value ?? context.User.Identity?.Name;
                        }
                        <span class="user-info">
                            <strong>@displayName</strong>
                            <span class="badge ms-2" style="background-color: @role.GetBadgeColor()">
                                @role.GetDisplayName()
                            </span>
                        </span>
                        <form method="post" action="/account/logout" style="display:inline;">
                            <AntiforgeryToken />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Вийти</button>
                        </form>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
